---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import JsonLd from '../components/JsonLd.astro';
import { PHONE, PHONE_RAW, EMAIL, SITE_URL } from '../consts';

const title = 'Funeral Director Staffing | NC & SC';
const description = 'Licensed funeral director staffing for NC and SC funeral homes. Overflow, vacation, emergency coverage & preneed counseling. 20+ years experience. Call (919) 822-2010.';

const serviceJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Funeral Home Staffing Services',
	description: 'Licensed funeral director staffing for funeral homes in North Carolina and South Carolina. Overflow, vacation, emergency, and preneed counseling.',
	provider: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
	},
	areaServed: [
		{ '@type': 'State', name: 'North Carolina' },
		{ '@type': 'State', name: 'South Carolina' },
	],
	serviceType: 'Funeral Director Staffing',
};
---

<BaseLayout title={title} description={description}>
  <Hero variant="interior" title="Funeral Home Staffing — NC & SC" subtitle="Licensed preneed funeral director available for staffing support across North Carolina and South Carolina" />

  <section class="py-12 md:py-16 bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Funeral Home Staffing' }]} />

      <p class="text-lg text-charcoal-500 mb-10 max-w-2xl">
        Duane Cutlip is a Licensed Preneed Funeral Director with over 20 years of experience, licensed in both North Carolina and South Carolina. He's available to support funeral homes across both states with professional, reliable staffing when you need it most.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="rounded-lg border border-border-light bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2">Overflow Coverage</h3>
          <p class="text-charcoal-500">When your team is stretched thin during high-volume periods, Duane can step in to handle pre-need consultations, family meetings, and arrangement conferences.</p>
        </div>

        <div class="rounded-lg border border-border-light bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2">Vacation Relief</h3>
          <p class="text-charcoal-500">Your staff deserves time off. Duane provides seamless coverage so your team can recharge without disrupting service to families.</p>
        </div>

        <div class="rounded-lg border border-border-light bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2">Emergency Staffing</h3>
          <p class="text-charcoal-500">Unexpected absences happen. Duane is available on short notice to ensure your funeral home maintains its standard of care.</p>
        </div>

        <div class="rounded-lg border border-border-light bg-white p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
            <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2">Pre-Need Counseling</h3>
          <p class="text-charcoal-500">If your funeral home wants to offer pre-need services but doesn't have a dedicated preneed counselor, Duane can fill that role on a contract basis.</p>
        </div>
      </div>

      <div class="rounded-lg bg-linen border border-border-light p-8">
        <h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-4">Contact Duane for Staffing Inquiries</h2>
        <p class="text-charcoal-500 mb-6">
          Duane is available for short-term and ongoing staffing arrangements throughout North Carolina and South Carolina. Whether you need overflow support, vacation relief, emergency coverage, or a dedicated preneed counselor, he's ready to help your funeral home maintain its standard of care.
        </p>
        <div class="flex flex-wrap gap-6">
          <a href={`tel:${PHONE_RAW}`} class="inline-flex items-center gap-2 text-xl font-heading font-bold text-burgundy-600 hover:text-burgundy-700">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            {PHONE}
          </a>
          <a href={`mailto:${EMAIL}`} class="inline-flex items-center gap-2 text-lg text-teal-600 hover:text-teal-700 font-medium">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            {EMAIL}
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner title="Looking for Pre-Need Insurance?" subtitle="If you're a family looking to plan ahead, Duane can help with that too." />

  <JsonLd data={serviceJsonLd} />
</BaseLayout>
