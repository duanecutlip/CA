---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CTABanner from '../../components/CTABanner.astro';
import JsonLd from '../../components/JsonLd.astro';
import { PHONE, PHONE_RAW, SITE_URL } from '../../consts';

const title = 'Speaking & Seminars | Duane Cutlip';
const description = 'Book Duane Cutlip for keynotes, workshops, and seminars on preneed programs, sales strategy, compliance, and funeral home modernization.';

const serviceJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Speaking & Seminars',
	description: 'Speaking engagements, keynotes, and workshops on preneed programs, sales strategy, and funeral home modernization.',
	provider: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
	},
	areaServed: { '@type': 'State', name: 'North Carolina' },
	serviceType: 'Speaking & Seminars',
};
---

<BaseLayout title={title} description={description} keywords="funeral home speaker, preneed seminar speaker, NFDA conference speaker, funeral industry keynote">
	<Hero variant="interior" title="Invite Duane to Speak at Your Next Event" subtitle="Practical, experience-driven presentations on preneed, sales strategy, and modernizing the funeral profession." />

	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'For Funeral Homes', href: '/for-funeral-homes' }, { label: 'Speaking' }]} />

		<!-- Overview -->
		<section class="mb-16">
			<div class="prose max-w-none text-charcoal-700 space-y-4">
				<p class="text-lg leading-relaxed">
					Duane Cutlip brings nearly 20 years of hands-on preneed experience to the stage. His presentations are built on real-world results, not theory — every story, every strategy, and every data point comes from actual work with funeral homes across North Carolina.
				</p>
				<p class="leading-relaxed">
					Whether you're planning a funeral home retreat, a state association conference, a carrier training event, or a community workshop, Duane delivers practical, actionable content your audience can use immediately. No corporate jargon, no recycled slide decks — just honest insights from a practitioner who does this work every day.
				</p>
			</div>
		</section>

		<!-- Speaking Topics -->
		<section class="mb-16">
			<SectionHeading title="Speaking Topics" accent />
			<div class="grid sm:grid-cols-2 gap-6">
				{[
					{ title: 'The State of Preneed', desc: 'Where the preneed industry stands today, what\'s changing, and what funeral homes need to do differently. Covers market trends, consumer behavior shifts, regulatory developments, and competitive pressures that are reshaping preneed in North Carolina and beyond.' },
					{ title: 'Building a Preneed Program from Scratch', desc: 'A step-by-step blueprint for funeral homes that want to launch a preneed program or completely rebuild one that isn\'t working. Covers carrier selection, staffing, lead generation, sales process design, and the first 90 days of execution.' },
					{ title: 'The Community Seminar Playbook', desc: 'Duane\'s proven model for community-based preneed lead generation. How to partner with churches and civic organizations, structure the presentation, capture interest, and convert attendees into funded contracts.' },
					{ title: 'Preneed Compliance Deep Dive', desc: 'North Carolina preneed regulations explained in plain English. Contract requirements, disclosure obligations, trust arrangements, and the most common compliance mistakes Duane sees in his audit work — and how to avoid them.' },
					{ title: 'The Cremation Shift and Preneed', desc: 'Cremation rates in North Carolina continue to climb. This presentation covers how the cremation trend affects preneed strategy, why cremation families still need preneed planning, and how to adjust your program for a market that\'s moving away from traditional burial.' },
					{ title: 'Technology Modernization for Funeral Homes', desc: 'From AI-powered CRM systems to digital lead generation and online preneed tools, Duane shares how technology can modernize funeral home operations without losing the personal touch that families expect. Built from his own experience implementing these tools.' },
				].map((topic) => (
					<div class="bg-white rounded-xl p-6 border border-border-light">
						<h3 class="font-heading font-bold text-charcoal-900 text-lg mb-2">{topic.title}</h3>
						<p class="text-charcoal-500 text-sm leading-relaxed">{topic.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Audiences -->
		<section class="mb-16">
			<SectionHeading title="Audiences & Events" accent />
			<div class="space-y-4 text-charcoal-700">
				<p class="leading-relaxed">Duane has spoken to audiences ranging from individual funeral home teams to multi-state association conferences. His content adapts to the audience — from tactical how-to for frontline staff to strategic outlook for owners and executives.</p>
				<ul class="space-y-3">
					{[
						{ bold: 'Funeral home retreats and team meetings', text: 'Private presentations for your staff, focused on your specific goals and challenges. Often combined with a training workshop for maximum impact.' },
						{ bold: 'State association conferences', text: 'NCFDA and regional association events. Duane delivers content that\'s relevant to the NC regulatory and market environment.' },
						{ bold: 'NFDA and national events', text: 'Broader industry presentations on preneed trends, technology modernization, and the future of the profession.' },
						{ bold: 'Carrier events and training sessions', text: 'Presentations for preneed insurance carriers and their funeral home partners. Duane provides the practitioner\'s perspective that complements carrier-provided content.' },
						{ bold: 'Church and community workshops', text: 'Public-facing educational events that serve as preneed lead generation for sponsoring funeral homes. Duane can lead these directly or train your staff to run them independently.' },
					].map((item) => (
						<li class="flex items-start gap-3">
							<svg class="w-5 h-5 text-teal-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
							</svg>
							<span><strong class="text-charcoal-900">{item.bold}:</strong> {item.text}</span>
						</li>
					))}
				</ul>
			</div>
		</section>

		<!-- Format Options -->
		<section class="mb-16">
			<SectionHeading title="Format Options" accent />
			<div class="grid sm:grid-cols-3 gap-6">
				{[
					{ title: 'Keynote', duration: '45-60 minutes', desc: 'A focused, high-energy presentation on a single topic. Ideal for conference main stages, association luncheons, and opening or closing sessions.' },
					{ title: 'Workshop', duration: 'Half or full day', desc: 'Interactive, hands-on sessions where attendees work through exercises, practice scenarios, and leave with specific tools they can apply immediately.' },
					{ title: 'Seminar Series', duration: 'Multi-session', desc: 'A series of connected presentations over weeks or months. Ideal for funeral homes implementing a new preneed program or associations offering ongoing education.' },
				].map((format) => (
					<div class="bg-white rounded-xl p-6 border border-border-light">
						<h3 class="font-heading font-bold text-charcoal-900 text-lg mb-1">{format.title}</h3>
						<p class="text-teal-600 text-sm font-medium mb-3">{format.duration}</p>
						<p class="text-charcoal-500 text-sm leading-relaxed">{format.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Speaker Bio -->
		<section class="mb-16">
			<div class="bg-linen rounded-xl p-8 border border-border-light">
				<h3 class="font-heading font-bold text-charcoal-900 text-xl mb-3">About Duane</h3>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					Duane Cutlip is a Licensed Preneed Funeral Director with nearly 20 years of experience in the funeral profession. He is a member of the National Funeral Directors Association (NFDA) and is associated with Donaldson Funeral Home & Crematory in Pittsboro, NC.
				</p>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					Duane has built preneed programs from the ground up, turned around underperforming operations, trained hundreds of funeral home staff members, and helped funeral homes navigate carrier transitions. He brings a practitioner's perspective to every presentation — grounded in real results, not academic theory.
				</p>
				<p class="text-charcoal-700 leading-relaxed">
					Outside the funeral industry, Duane is unusually tech-forward — he's built AI-powered CRM systems, assembled his own servers, and stays on the cutting edge of technology that can benefit funeral home operations. His presentations on technology modernization reflect firsthand experience, not secondhand research.
				</p>
			</div>
		</section>

		<!-- Upcoming Events -->
		<section class="mb-16">
			<SectionHeading title="Upcoming Events" accent />
			<div class="bg-white rounded-xl p-8 border border-border-light text-center">
				<p class="text-charcoal-500 leading-relaxed">
					Upcoming speaking engagements will be listed here. Check back soon, or contact Duane to discuss booking him for your event.
				</p>
			</div>
		</section>

		<!-- CTA -->
		<section class="mb-8">
			<div class="prose max-w-none text-charcoal-700 space-y-4">
				<h2 class="font-heading text-2xl font-bold text-charcoal-900">Book Duane for Your Event</h2>
				<p class="leading-relaxed">
					Call Duane at <a href={`tel:${PHONE_RAW}`} class="text-burgundy-600 font-bold hover:text-burgundy-700">{PHONE}</a> to discuss your event, audience, and preferred topic. He'll work with you to tailor the content to your attendees and ensure maximum relevance. Speaking fees vary by format and travel requirements — the conversation starts with understanding your needs.
				</p>
			</div>
		</section>
	</div>

	<CTABanner title="Book Duane for Your Next Event" subtitle="Call to discuss topics, format, and availability for your conference, retreat, or workshop." />

	<JsonLd data={serviceJsonLd} />
</BaseLayout>
