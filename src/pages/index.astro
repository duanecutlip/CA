---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BenefitCard from '../components/BenefitCard.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutSection from '../components/AboutSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTABanner from '../components/CTABanner.astro';
import SchedulingWidgetPlaceholder from '../components/SchedulingWidgetPlaceholder.astro';
import ServiceAreaList from '../components/ServiceAreaList.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, SITE_URL, PHONE, EMAIL, BENEFITS, SERVICE_AREAS } from '../consts';

const title = `Pre-Need Insurance Raleigh NC | ${SITE_TITLE}`;
const description = `Protect your family from unexpected funeral costs. Call ${PHONE}. Duane Cutlip, Licensed Preneed Funeral Director, nearly 20 years serving Raleigh & Wake County NC.`;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': 'https://cutlipassociates.com/#website',
	name: SITE_TITLE,
	url: SITE_URL,
};

const localBusinessJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': 'https://cutlipassociates.com/#local-business',
	name: SITE_TITLE,
	telephone: PHONE,
	email: EMAIL,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Wendell',
		addressRegion: 'NC',
		postalCode: '27591',
		addressCountry: 'US',
	},
	areaServed: SERVICE_AREAS.map((area) => ({
		'@type': 'City',
		name: `${area.name}, ${area.state}`,
	})),
	priceRange: '$$',
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '17:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '09:00',
			closes: '12:00',
			description: 'By appointment only',
		},
	],
	employee: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
		telephone: PHONE,
	},
};
---

<BaseLayout title={title} description={description}>
	<Hero
		variant="home"
		title="Pre-Need Funeral Planning for North Carolina Families"
		subtitle="The most loving thing you can do for your family is make these decisions while you're here to make them — so they're never left guessing what you would have wanted, and never blindsided by costs they didn't see coming."
	/>

	<TrustBar />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Why Plan Ahead?
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto">
					Planning ahead isn't about dying — it's about living with the peace of knowing your family is protected.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-6">
				{BENEFITS.map((benefit) => (
					<BenefitCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon as 'heart' | 'shield' | 'star'}
					/>
				))}
			</div>
		</div>
	</section>

	<TestimonialSection />

	<ProcessSteps />

	<section class="py-14 md:py-20 bg-linen">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="font-heading text-2xl md:text-3xl font-bold text-charcoal-900 mb-4">
					What Funerals Actually Cost — And Why the Numbers Are Confusing
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto leading-relaxed">
					Families often arrive with a number in their head — $1,995 or $8,300 — that doesn't reflect what they'll actually spend. Here's why, and what a complete arrangement actually looks like.
				</p>
			</div>
			<div class="grid md:grid-cols-2 gap-6 mb-8">
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Direct cremation — no service</p>
					<p class="text-xs text-charcoal-400 mb-4">Advertised starting at $1,995–$3,900+</p>
					<p class="text-sm text-charcoal-600 leading-relaxed mb-3">
						Covers transportation, cremation, and return of remains — nothing more. No visitation. No memorial service. No gathering for the family to grieve together.
					</p>
					<p class="text-sm text-charcoal-500 leading-relaxed italic">
						Each year, funeral homes across NC receive calls from families who found a loved one's urn in an attic or closet, still waiting to be claimed. Minimal arrangements often leave families without the ritual they needed to say goodbye.
					</p>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">NFDA median — some services included</p>
					<p class="text-xs text-charcoal-400 mb-4">Industry average: $8,300</p>
					<p class="text-sm text-charcoal-600 leading-relaxed mb-3">
						This figure covers the funeral home's basic service fees, a casket, and typically a viewing or service — but not the cemetery, vault, plot, opening &amp; closing fees, or marker.
					</p>
					<ul class="space-y-2 text-xs text-charcoal-500 border-t border-border-light pt-3 mt-3">
						<li class="flex justify-between gap-2"><span>Burial vault (req. by most cemeteries)</span><span class="font-semibold whitespace-nowrap">$1,000–$3,500</span></li>
						<li class="flex justify-between gap-2"><span>Cemetery plot</span><span class="font-semibold whitespace-nowrap">$2,000–$8,000</span></li>
						<li class="flex justify-between gap-2"><span>Opening &amp; closing fees</span><span class="font-semibold whitespace-nowrap">$1,000–$2,500</span></li>
						<li class="flex justify-between gap-2"><span>Grave marker / headstone</span><span class="font-semibold whitespace-nowrap">$1,500–$5,000</span></li>
					</ul>
				</div>
			</div>
			<div class="bg-white border border-teal-200 rounded-xl p-6">
				<p class="text-charcoal-700 leading-relaxed text-center mb-3">
					<strong class="text-charcoal-900">Complete arrangements</strong> — whether cremation with a memorial service, or a traditional burial — typically run <strong class="text-charcoal-900">$8,000–$12,000 for cremation with services</strong> and <strong class="text-charcoal-900">$12,000–$20,000 for traditional burial</strong> when all necessary expenses are counted. Funeral costs have risen 40% in the last decade, and a pre-need plan with an Inflation Proof Guarantee means the funeral home accepts your plan as payment in full for covered services — whatever costs do between now and then.
				</p>
				<p class="text-charcoal-500 text-sm text-center leading-relaxed">
					Nobody is trying to alarm you. Duane just believes in giving you the complete picture — because <em>good information makes good decisions.</em>
				</p>
				<div class="text-center mt-4">
					<a href="/learn/preneed-insurance-nc" class="text-teal-700 hover:text-teal-800 text-sm font-medium underline">
						Learn exactly what pre-need insurance covers →
					</a>
				</div>
			</div>
		</div>
	</section>

	<AboutSection />

	<FAQSection limit={6} title="Common Questions" subtitle="The answers families ask for most — before they even pick up the phone." />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Can't Call Right Now?
				</h2>
				<p class="text-charcoal-500 max-w-xl mx-auto">
					Pick a time that works for you. Duane will call you personally — no salespeople, no pressure.
				</p>
			</div>
			<SchedulingWidgetPlaceholder heading="Pick a Time" subheading="Choose a date and time below and Duane will call you at that exact time." />
		</div>
	</section>

	<CTABanner />

	<ServiceAreaList />

	<JsonLd data={websiteJsonLd} />
	<JsonLd data={localBusinessJsonLd} />
</BaseLayout>
