---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BenefitCard from '../components/BenefitCard.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutSection from '../components/AboutSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTABanner from '../components/CTABanner.astro';
import SchedulingWidgetPlaceholder from '../components/SchedulingWidgetPlaceholder.astro';
import ServiceAreaList from '../components/ServiceAreaList.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, SITE_URL, PHONE, EMAIL, BENEFITS, SERVICE_AREAS } from '../consts';

const title = `Pre-Need Insurance Raleigh NC | ${SITE_TITLE}`;
const description = `Protect your family from unexpected funeral costs. Call ${PHONE}. Duane Cutlip, Licensed Preneed Funeral Director, nearly 20 years serving Raleigh & Wake County NC.`;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': 'https://cutlipassociates.com/#website',
	name: SITE_TITLE,
	url: SITE_URL,
};

const localBusinessJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': 'https://cutlipassociates.com/#local-business',
	name: SITE_TITLE,
	telephone: PHONE,
	email: EMAIL,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Wendell',
		addressRegion: 'NC',
		postalCode: '27591',
		addressCountry: 'US',
	},
	areaServed: SERVICE_AREAS.map((area) => ({
		'@type': 'City',
		name: `${area.name}, ${area.state}`,
	})),
	priceRange: '$$',
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '17:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '09:00',
			closes: '12:00',
			description: 'By appointment only',
		},
	],
	employee: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
		telephone: PHONE,
	},
};
---

<BaseLayout title={title} description={description}>
	<Hero
		variant="home"
		title="Pre-Need Funeral Planning for North Carolina Families"
		subtitle="The most loving thing you can do for your family is make these decisions while you're here to make them — so they're never left guessing what you would have wanted, and never blindsided by costs they didn't see coming."
	/>

	<TrustBar />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Why Plan Ahead?
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto">
					Planning ahead isn't about dying — it's about living with the peace of knowing your family is protected.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-6">
				{BENEFITS.map((benefit) => (
					<BenefitCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon as 'heart' | 'shield' | 'star'}
					/>
				))}
			</div>
		</div>
	</section>

	{/* TestimonialSection hidden pending verified client testimonials */}

	<ProcessSteps />

	<section class="py-10 bg-white border-y border-border-light">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col sm:flex-row items-center justify-between gap-6">
				<div>
					<p class="text-xs font-heading font-bold text-teal-600 uppercase tracking-widest mb-1">If you're in your 60s</p>
					<h2 class="font-heading text-xl md:text-2xl font-bold text-charcoal-900">This is the best window you'll ever have.</h2>
					<p class="text-charcoal-500 mt-1 text-sm leading-relaxed max-w-lg">Rates are lower, coverage is better, and the decisions are entirely yours. Most people who wait say they wish they hadn't.</p>
				</div>
				<a href="/planning-in-your-60s" class="flex-shrink-0 bg-teal-600 hover:bg-teal-700 text-white font-heading font-bold px-6 py-3 rounded-xl transition-colors whitespace-nowrap">
					Why Your 60s Matter →
				</a>
			</div>
		</div>
	</section>

	<section class="py-14 md:py-20 bg-linen">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="font-heading text-2xl md:text-3xl font-bold text-charcoal-900 mb-4">
					What a Funeral Actually Costs in North Carolina
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto leading-relaxed">
					Prices vary widely depending on what's included. Here's what those numbers actually mean — and what most families are surprised to learn isn't covered.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-5 mb-8">
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Direct Cremation</p>
					<p class="text-xs text-teal-700 font-semibold mb-3">No service · Funeral home only</p>
					<p class="text-2xl font-heading font-bold text-charcoal-900 mb-3">$4,000+</p>
					<p class="text-sm text-charcoal-600 leading-relaxed mb-3">
						Transportation, cremation, and return of remains — nothing more. No visitation. No memorial service. No gathering for the family to grieve together.
					</p>
					<p class="text-xs text-charcoal-400 leading-relaxed italic">
						Funeral homes across NC receive calls from families who found a loved one's urn years later, still waiting to be claimed. Minimal arrangements often leave families without the closure they needed.
					</p>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Cremation with Memorial Service</p>
					<p class="text-xs text-teal-700 font-semibold mb-3">Service after cremation · Funeral home only</p>
					<p class="text-2xl font-heading font-bold text-charcoal-900 mb-3">$6,000–$8,000</p>
					<p class="text-sm text-charcoal-600 leading-relaxed mb-3">
						A service is held — with music, readings, and a gathering — but the body is not present. Allows the family to grieve together and honor their loved one meaningfully.
					</p>
					<p class="text-xs text-charcoal-400 leading-relaxed">
						Does not include: urn niche or cemetery plot, opening &amp; closing fees, grave marker.
					</p>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Traditional Service with Cremation</p>
					<p class="text-xs text-teal-700 font-semibold mb-3">Body present at service · Funeral home only</p>
					<p class="text-2xl font-heading font-bold text-charcoal-900 mb-3">$8,000–$10,000</p>
					<p class="text-sm text-charcoal-600 leading-relaxed mb-3">
						A full service with the body present — viewing, funeral service — followed by cremation. The most complete option for families who want the full ritual of a traditional service.
					</p>
					<p class="text-xs text-charcoal-400 leading-relaxed">
						Does not include: urn niche or cemetery plot, opening &amp; closing fees, grave marker.
					</p>
				</div>
			</div>
			<div class="bg-white border border-teal-200 rounded-xl p-6">
				<p class="text-charcoal-700 leading-relaxed text-center mb-3">
					<strong class="text-charcoal-900">None of the above prices include cemetery costs</strong> — urn niche or burial plot, opening &amp; closing fees, and a grave marker can add <strong class="text-charcoal-900">$3,000–$10,000 or more</strong>. A traditional burial with casket and full cemetery costs typically runs <strong class="text-charcoal-900">$15,000–$22,000</strong> all in. Funeral costs have risen 40% in the last decade — and a pre-need plan with an <strong class="text-charcoal-900">Inflation Proof Guarantee</strong> means the funeral home accepts your plan as payment in full for covered services, whatever those services cost when the time comes.
				</p>
				<p class="text-charcoal-500 text-sm text-center leading-relaxed">
					Nobody is trying to alarm you. Duane just believes in giving you the complete picture — because <em>good information makes good decisions.</em>
				</p>
				<div class="text-center mt-4">
					<a href="/learn/preneed-insurance-nc" class="text-teal-700 hover:text-teal-800 text-sm font-medium underline">
						Learn exactly what pre-need insurance covers →
					</a>
				</div>
			</div>
		</div>
	</section>

	<AboutSection />

	<FAQSection limit={6} title="Common Questions" subtitle="The answers families ask for most — before they even pick up the phone." />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Can't Call Right Now?
				</h2>
				<p class="text-charcoal-500 max-w-xl mx-auto">
					Pick a time that works for you. Duane will call you personally — no salespeople, no pressure.
				</p>
			</div>
			<SchedulingWidgetPlaceholder heading="Pick a Time" subheading="Choose a date and time below and Duane will call you at that exact time." />
		</div>
	</section>

	<CTABanner />

	<ServiceAreaList />

	<JsonLd data={websiteJsonLd} />
	<JsonLd data={localBusinessJsonLd} />
</BaseLayout>
