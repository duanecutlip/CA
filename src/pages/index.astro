---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BenefitCard from '../components/BenefitCard.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutSection from '../components/AboutSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTABanner from '../components/CTABanner.astro';
import SchedulingWidgetPlaceholder from '../components/SchedulingWidgetPlaceholder.astro';
import ServiceAreaList from '../components/ServiceAreaList.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, SITE_URL, PHONE, EMAIL, BENEFITS, SERVICE_AREAS } from '../consts';

const title = `Pre-Need Insurance Raleigh NC | ${SITE_TITLE}`;
const description = `Protect your family from unexpected funeral costs. Call ${PHONE}. Duane Cutlip, Licensed Preneed Funeral Director, nearly 20 years serving Raleigh & Wake County NC.`;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': 'https://cutlipassociates.com/#website',
	name: SITE_TITLE,
	url: SITE_URL,
};

const localBusinessJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': 'https://cutlipassociates.com/#local-business',
	name: SITE_TITLE,
	telephone: PHONE,
	email: EMAIL,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Wendell',
		addressRegion: 'NC',
		postalCode: '27591',
		addressCountry: 'US',
	},
	areaServed: SERVICE_AREAS.map((area) => ({
		'@type': 'City',
		name: `${area.name}, ${area.state}`,
	})),
	priceRange: '$$',
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '17:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '09:00',
			closes: '12:00',
			description: 'By appointment only',
		},
	],
	employee: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
		telephone: PHONE,
	},
};
---

<BaseLayout title={title} description={description}>
	<Hero
		variant="home"
		title="Pre-Need Funeral Planning for North Carolina Families"
		subtitle="The most loving thing you can do for your family is make these decisions while you're here to make them — so they're never left guessing what you would have wanted, and never blindsided by costs they didn't see coming."
	/>

	<TrustBar />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Why Plan Ahead?
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto">
					Planning ahead isn't about dying — it's about living with the peace of knowing your family is protected.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-6">
				{BENEFITS.map((benefit) => (
					<BenefitCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon as 'heart' | 'shield' | 'star'}
					/>
				))}
			</div>
		</div>
	</section>

	<TestimonialSection />

	<ProcessSteps />

	<section class="py-14 md:py-20 bg-linen">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="font-heading text-2xl md:text-3xl font-bold text-charcoal-900 mb-4">
					Why Funeral Costs Are Higher Than Most Families Expect
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto leading-relaxed">
					You may have seen direct cremation advertised for $1,995, or heard the industry average of $8,300. Both figures are real — but they rarely reflect what a family actually pays. The items below are almost always necessary, and almost never included in those numbers.
				</p>
			</div>
			<div class="grid md:grid-cols-2 gap-6 mb-8">
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-4">Commonly quoted figures</p>
					<ul class="space-y-3 text-sm text-charcoal-500">
						<li class="flex justify-between gap-4">
							<span>Direct cremation (advertised)</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$1,995–$3,000</span>
						</li>
						<li class="flex justify-between gap-4">
							<span>NFDA median funeral cost</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$8,300</span>
						</li>
					</ul>
					<p class="text-xs text-charcoal-400 mt-4 leading-relaxed">These cover the funeral home's service fees — but most families need more than that to complete the arrangements.</p>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-4">What's typically not included</p>
					<ul class="space-y-3 text-sm text-charcoal-500">
						<li class="flex justify-between gap-4">
							<span>Burial vault (required by most cemeteries)</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$1,000–$3,500</span>
						</li>
						<li class="flex justify-between gap-4">
							<span>Cemetery plot</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$2,000–$8,000</span>
						</li>
						<li class="flex justify-between gap-4">
							<span>Opening &amp; closing fees</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$1,000–$2,500</span>
						</li>
						<li class="flex justify-between gap-4">
							<span>Grave marker / headstone</span>
							<span class="font-semibold text-charcoal-700 whitespace-nowrap">$1,500–$5,000</span>
						</li>
					</ul>
				</div>
			</div>
			<div class="bg-white border border-teal-200 rounded-xl p-6">
				<p class="text-charcoal-700 leading-relaxed text-center">
					<strong class="text-charcoal-900">When all real expenses are counted</strong>, North Carolina families typically spend $12,000–$20,000 on a traditional burial — and costs have risen 40% in the last decade. Pre-need insurance locks in today's prices across every one of those expenses, before they rise any further. Nobody is trying to alarm you. Duane just believes in giving you the complete picture — because <em>good information makes good decisions.</em>
				</p>
				<div class="text-center mt-4">
					<a href="/learn/preneed-insurance-nc" class="text-teal-700 hover:text-teal-800 text-sm font-medium underline">
						Learn exactly what pre-need insurance covers →
					</a>
				</div>
			</div>
		</div>
	</section>

	<AboutSection />

	<FAQSection limit={6} title="Common Questions" subtitle="The answers families ask for most — before they even pick up the phone." />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Can't Call Right Now?
				</h2>
				<p class="text-charcoal-500 max-w-xl mx-auto">
					Pick a time that works for you. Duane will call you personally — no salespeople, no pressure.
				</p>
			</div>
			<SchedulingWidgetPlaceholder heading="Pick a Time" subheading="Choose a date and time below and Duane will call you at that exact time." />
		</div>
	</section>

	<CTABanner />

	<ServiceAreaList />

	<JsonLd data={websiteJsonLd} />
	<JsonLd data={localBusinessJsonLd} />
</BaseLayout>
