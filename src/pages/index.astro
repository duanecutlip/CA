---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BenefitCard from '../components/BenefitCard.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutSection from '../components/AboutSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTABanner from '../components/CTABanner.astro';
import SchedulingWidgetPlaceholder from '../components/SchedulingWidgetPlaceholder.astro';
import ServiceAreaList from '../components/ServiceAreaList.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, SITE_URL, PHONE, EMAIL, BENEFITS, SERVICE_AREAS } from '../consts';

const title = `Pre-Need Insurance Raleigh NC | ${SITE_TITLE}`;
const description = `Protect your family from unexpected funeral costs. Call ${PHONE}. Duane Cutlip, Licensed Preneed Funeral Director, nearly 20 years serving Raleigh & Wake County NC.`;

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': 'https://cutlipassociates.com/#website',
	name: SITE_TITLE,
	url: SITE_URL,
};

const localBusinessJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': 'https://cutlipassociates.com/#local-business',
	name: SITE_TITLE,
	telephone: PHONE,
	email: EMAIL,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Wendell',
		addressRegion: 'NC',
		postalCode: '27591',
		addressCountry: 'US',
	},
	areaServed: SERVICE_AREAS.map((area) => ({
		'@type': 'City',
		name: `${area.name}, ${area.state}`,
	})),
	priceRange: '$$',
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '17:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '09:00',
			closes: '12:00',
			description: 'By appointment only',
		},
	],
	employee: {
		'@type': 'Person',
		'@id': 'https://cutlipassociates.com/#duane-cutlip',
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Preneed Funeral Director',
		telephone: PHONE,
	},
};
---

<BaseLayout title={title} description={description}>
	<Hero
		variant="home"
		title="Pre-Need Funeral Planning for North Carolina Families"
		subtitle="At 60+, the most loving gift you can give is deciding now — so your adult children never have to guess what you would have wanted, and never get blindsided by costs they didn't see coming."
	/>

	<TrustBar />

	<section class="py-10 bg-linen border-t border-b border-border-light">
		<div class="max-w-2xl mx-auto px-4 text-center">
			<p class="font-heading text-xl font-bold text-charcoal-900 mb-2">Not sure where to start?</p>
			<p class="text-charcoal-500 mb-5">Download the free Pre-Planning Checklist — a simple guide to the decisions you'll want to make now, so your family never has to make them later.</p>
			<a href="/resources/pre-planning-checklist" class="inline-block bg-teal-600 text-white px-8 py-4 rounded-full text-base font-semibold hover:bg-teal-700 transition-colors">
				View the Free Pre-Planning Checklist
			</a>
			<p class="text-sm text-charcoal-400 mt-3">No form, no obligation — just helpful information. Duane will walk through it with you if you'd like to call.</p>
		</div>
	</section>

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Why Plan Ahead?
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto">
					Planning ahead isn't about dying — it's about living with the peace of knowing your family is protected.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-6">
				{BENEFITS.map((benefit) => (
					<BenefitCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon as 'heart' | 'shield' | 'star'}
					/>
				))}
			</div>
		</div>
	</section>

	{/* TestimonialSection hidden pending verified client testimonials */}

	<ProcessSteps />

	<section class="py-10 bg-white border-y border-border-light">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col sm:flex-row items-center justify-between gap-6">
				<div>
					<p class="text-xs font-heading font-bold text-teal-600 uppercase tracking-widest mb-1">If you're in your 60s</p>
					<h2 class="font-heading text-xl md:text-2xl font-bold text-charcoal-900">This is the best window you'll ever have.</h2>
					<p class="text-charcoal-500 mt-1 text-sm leading-relaxed max-w-lg">Rates are lower, coverage is better, and the decisions are entirely yours. Most people who wait say they wish they hadn't.</p>
				</div>
				<a href="/planning-in-your-60s" class="flex-shrink-0 bg-teal-600 hover:bg-teal-700 text-white font-heading font-bold px-6 py-3 rounded-xl transition-colors whitespace-nowrap">
					Why Your 60s Matter →
				</a>
			</div>
		</div>
	</section>

	<section class="py-14 md:py-20 bg-linen">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-10">
				<h2 class="font-heading text-2xl md:text-3xl font-bold text-charcoal-900 mb-4">
					What Funerals Actually Cost — And What That Really Means
				</h2>
				<p class="text-charcoal-500 max-w-2xl mx-auto leading-relaxed">
					Some providers advertise eye-catching low prices. Here's the fuller picture — what families in NC actually spend, what those choices mean, and why planning ahead saves more than planning minimally.
				</p>
			</div>

			<!-- The "simple" myth -->
			<div class="bg-white rounded-xl border border-border-light p-6 mb-6">
				<h3 class="font-heading font-bold text-charcoal-900 mb-3">The Word "Simple" Means Different Things to Different Families</h3>
				<p class="text-charcoal-700 leading-relaxed mb-3">
					You'll see advertisements for "simple cremation" or "direct cremation" starting under $1,000. What they're describing is transportation, cremation, and return of remains — no gathering, no service, no opportunity for the family to come together, grieve, and say goodbye. For families who have no other option, it exists. But for families who choose it primarily to save money, it often becomes one of the most painful regrets Duane hears about years later.
				</p>
				<p class="text-charcoal-700 leading-relaxed">
					The difference in cost between the most minimal arrangement and a meaningful one is often a few thousand dollars — an amount that wouldn't pay a month of most families' bills. The grief that comes from not having a proper service can last a lifetime. "Simple" doesn't have to mean no service. It can mean elegant, intentional, and exactly right for who your loved one was.
				</p>
			</div>

			<!-- Realistic cost ranges -->
			<div class="grid md:grid-cols-2 gap-5 mb-6">
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Cremation with Services</p>
					<p class="text-xs text-teal-700 font-semibold mb-3">Memorial or traditional service · Funeral home only</p>
					<p class="text-2xl font-heading font-bold text-charcoal-900 mb-3">$6,000–$12,000+</p>
					<p class="text-sm text-charcoal-600 leading-relaxed">
						This is what most families who choose cremation actually spend when they include a meaningful service — music, readings, a gathering where family and friends can grieve together. Ranges vary by funeral home, service selections, and whether the body is present at the service.
					</p>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<p class="font-heading font-bold text-charcoal-900 mb-1">Traditional Burial with Services</p>
					<p class="text-xs text-teal-700 font-semibold mb-3">Visitation, funeral service, burial · Funeral home only</p>
					<p class="text-2xl font-heading font-bold text-charcoal-900 mb-3">$10,000–$20,000+</p>
					<p class="text-sm text-charcoal-600 leading-relaxed">
						A full traditional service with casket, visitation, and burial. For many families — particularly those with strong faith traditions or who want the most complete farewell — this remains the right choice regardless of cost.
					</p>
				</div>
			</div>

			<div class="bg-white border border-teal-200 rounded-xl p-6">
				<p class="text-charcoal-700 leading-relaxed mb-3">
					<strong class="text-charcoal-900">Neither estimate includes cemetery costs</strong> — burial plot or urn niche, opening &amp; closing fees, and a grave marker can add <strong class="text-charcoal-900">$3,000–$10,000 or more</strong>. Funeral costs have risen 40% in the last decade.
				</p>
				<p class="text-charcoal-700 leading-relaxed mb-3">
					<strong class="text-charcoal-900">Planning ahead saves more than planning minimally.</strong> A pre-need plan with an <strong>Inflation Proof Guarantee</strong> means the funeral home accepts your plan as payment in full for covered services — whatever those services cost when the time comes. Your family pays nothing more on guaranteed items, and they make the decisions now, together, without grief clouding every choice.
				</p>
				<div class="text-center mt-4">
					<a href="/learn/preneed-insurance-nc" class="text-teal-700 hover:text-teal-800 text-sm font-medium underline">
						Learn exactly how pre-need insurance works →
					</a>
				</div>
			</div>
		</div>
	</section>

	<AboutSection />

	<FAQSection limit={6} title="Common Questions" subtitle="The answers families ask for most — before they even pick up the phone." />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
					Can't Call Right Now?
				</h2>
				<p class="text-charcoal-500 max-w-xl mx-auto">
					Pick a time that works for you. Duane will call you personally — no salespeople, no pressure.
				</p>
			</div>
			<SchedulingWidgetPlaceholder heading="Pick a Time" subheading="Choose a date and time below and Duane will call you at that exact time." />
		</div>
	</section>

	<CTABanner />

	<ServiceAreaList />

	<JsonLd data={websiteJsonLd} />
	<JsonLd data={localBusinessJsonLd} />
</BaseLayout>
