---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SERVICE_AREAS, PHONE } from '../../consts';

const ncAreas = SERVICE_AREAS.filter((a) => a.state === 'NC');

// Group NC areas by region
const ncCoreRegions = ['Wake County', 'Triangle', 'Johnston County'];
const ncCoreAreas = ncAreas.filter((a) => ncCoreRegions.includes(a.region || ''));
const ncExtendedAreas = ncAreas.filter((a) => !ncCoreRegions.includes(a.region || ''));

// Group by region for display
function groupByRegion(areas: typeof SERVICE_AREAS) {
  const groups: Record<string, typeof SERVICE_AREAS> = {};
  for (const area of areas) {
    const region = area.region || 'Other';
    if (!groups[region]) groups[region] = [];
    groups[region].push(area);
  }
  return groups;
}

const ncCoreGroups = groupByRegion(ncCoreAreas);
const ncExtendedGroups = groupByRegion(ncExtendedAreas);

const title = 'Pre-Need Insurance Service Areas | North Carolina';
const description = `Pre-need funeral planning across North Carolina. Raleigh, Durham, Fayetteville, Wake County, Triangle area & more. Call ${PHONE}.`;
---

<BaseLayout title={title} description={description}>
  <Hero variant="interior" title="Service Areas" subtitle="Duane serves families across North Carolina" />

  <section class="py-12 md:py-16 bg-warm-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Service Areas' }]} />

      <p class="text-lg text-charcoal-500 mb-10 max-w-2xl">
        Duane Cutlip is a Licensed Preneed Funeral Director serving families throughout North Carolina. Whether you're in the Raleigh metro, the Triangle, or anywhere in between, Duane is available to meet with you in person or by phone.
      </p>

      <!-- North Carolina — Core Areas -->
      <div class="mb-12">
        <h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-6">North Carolina</h2>

        {Object.entries(ncCoreGroups).map(([region, areas]) => (
          <div class="mb-6">
            <h3 class="font-heading text-base font-semibold text-charcoal-600 mb-3">{region}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
              {areas.map((area) => (
                <a
                  href={`/service-areas/${area.slug}`}
                  class="flex items-center gap-2 bg-white rounded-lg border border-border-light px-4 py-3 hover:border-teal-600/30 hover:bg-teal-600/5 transition-colors"
                >
                  <svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                  <span class="text-charcoal-700 font-medium text-sm">{area.name}</span>
                </a>
              ))}
            </div>
          </div>
        ))}

        <!-- Extended NC areas — collapsed by default -->
        <details class="group mt-4">
          <summary class="cursor-pointer inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-medium text-sm transition-colors">
            <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
            View all North Carolina service areas ({ncExtendedAreas.length} more towns)
          </summary>
          <div class="mt-4 space-y-6">
            {Object.entries(ncExtendedGroups).map(([region, areas]) => (
              <div>
                <h3 class="font-heading text-base font-semibold text-charcoal-600 mb-3">{region}</h3>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
                  {areas.map((area) => (
                    <a
                      href={`/service-areas/${area.slug}`}
                      class="flex items-center gap-2 bg-white rounded-lg border border-border-light px-4 py-3 hover:border-teal-600/30 hover:bg-teal-600/5 transition-colors"
                    >
                      <svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                      </svg>
                      <span class="text-charcoal-700 font-medium text-sm">{area.name}</span>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </details>
      </div>

      <div class="rounded-lg border border-border-light bg-linen p-6">
        <h2 class="font-heading text-xl font-bold text-charcoal-900 mb-2">Don't see your town?</h2>
        <p class="text-charcoal-500">
          Duane works with families throughout North Carolina. Even if your city isn't listed, give him a call at <a href="tel:9198222010" class="font-semibold text-teal-600 hover:text-teal-700">{PHONE}</a> — he's happy to help.
        </p>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
