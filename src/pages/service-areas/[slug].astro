---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQSection from '../../components/FAQSection.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SERVICE_AREAS, SITE_TITLE, SITE_URL, PHONE, PHONE_RAW, EMAIL } from '../../consts';

export function getStaticPaths() {
  return SERVICE_AREAS.map((area) => ({ params: { slug: area.slug }, props: { area } }));
}

interface Props {
  area: (typeof SERVICE_AREAS)[number];
}

const { area } = Astro.props;
const stateName = area.state === 'NC' ? 'North Carolina' : 'South Carolina';

const title = `Pre-Need Insurance in ${area.name}, ${area.state} | ${SITE_TITLE}`;
const description = `Pre-need funeral planning for families in ${area.name}, ${area.county} County ${area.state}. Lock in today's prices and protect your loved ones. Call ${PHONE}.`;

const cityFaqs: Record<string, { question: string; answer: string }[]> = {
  raleigh: [
    { question: `What funeral homes in Raleigh does Duane work with?`, answer: `Duane has relationships with respected funeral homes throughout Raleigh, including L. Harold Poole Funeral Home & Crematory. As a Licensed Preneed Funeral Director, he can coordinate your plan with the Raleigh funeral home of your choice.` },
    { question: `How much does a funeral cost in Raleigh, NC?`, answer: `The average funeral in the Raleigh area costs $7,848 or more, and costs continue to rise. Pre-need insurance locks in today's prices so your family never pays the difference.` },
    { question: `Can I meet Duane in person in Raleigh?`, answer: `Yes. Duane meets with Raleigh families in person at a location convenient to you — your home, a coffee shop, or wherever you're comfortable. He also offers phone consultations.` },
  ],
  cary: [
    { question: `Does Duane serve families in Cary?`, answer: `Absolutely. Cary is one of Duane's primary service areas in Wake County. He regularly meets with Cary families to help them plan ahead.` },
    { question: `What are typical funeral costs in Cary, NC?`, answer: `Funeral costs in Cary mirror the greater Raleigh area, averaging $7,848 or more. Pre-need planning locks in current prices and prevents future cost increases from burdening your family.` },
    { question: `Where can I meet with Duane in Cary?`, answer: `Duane is happy to meet you wherever is most convenient — your home in Cary, a local coffee shop, or by phone. There's no office visit required.` },
  ],
  apex: [
    { question: `Is pre-need insurance available in Apex, NC?`, answer: `Yes. Duane serves families throughout Apex and western Wake County. He can meet with you locally or by phone to discuss your options.` },
    { question: `How much does a funeral cost in the Apex area?`, answer: `Funeral costs in Apex are consistent with Wake County averages — $7,848 or more. Pre-need insurance ensures your family never has to cover rising costs.` },
    { question: `What funeral homes are near Apex?`, answer: `There are several funeral homes serving the Apex community. Duane can help you choose one that fits your preferences and coordinate your pre-need plan with them directly.` },
  ],
  garner: [
    { question: `Does Duane work with families in Garner?`, answer: `Yes. Garner is part of Duane's core service area in southern Wake County. He's helped many Garner families plan ahead with confidence.` },
    { question: `What does pre-need planning cost for Garner families?`, answer: `Most families invest between $3,000 and $15,000 depending on their preferences. Duane will walk you through options that fit your budget — no pressure, no obligation.` },
    { question: `Can I arrange a consultation in Garner?`, answer: `Of course. Duane meets with families in Garner at their home or another convenient location. He also offers phone consultations for those who prefer it.` },
  ],
  wendell: [
    { question: `Is Duane based in Wendell?`, answer: `Yes — Duane is based in Wendell, NC. He knows the community well and has helped many local families with their pre-need planning.` },
    { question: `What funeral homes serve Wendell, NC?`, answer: `Several funeral homes serve the Wendell area. Duane can help you evaluate your options and coordinate your plan with the home of your choice.` },
    { question: `How do I get started with pre-need planning in Wendell?`, answer: `Just call Duane at ${PHONE}. He'll have a short conversation to understand your needs, then schedule a time to go over your options in detail. Most plans are completed within two weeks.` },
  ],
  knightdale: [
    { question: `Does Duane serve Knightdale families?`, answer: `Yes. Knightdale is part of Duane's service area in eastern Wake County. He regularly meets with families there for pre-need consultations.` },
    { question: `What are funeral costs in the Knightdale area?`, answer: `Funeral costs in Knightdale are consistent with the greater Raleigh average of $7,848 or more. Pre-need insurance protects your family from these rising costs.` },
    { question: `Can Duane come to my home in Knightdale?`, answer: `Absolutely. Duane is happy to meet at your home, a local spot, or by phone — whatever makes you most comfortable.` },
  ],
  'wake-forest': [
    { question: `Does Duane serve Wake Forest, NC?`, answer: `Yes. Wake Forest is part of Duane's service area in northern Wake County. He works with families throughout the Wake Forest community.` },
    { question: `How much should I budget for funeral planning in Wake Forest?`, answer: `Most families invest between $3,000 and $15,000 for a comprehensive pre-need plan. Duane will help you find options that match your budget and preferences.` },
    { question: `What funeral homes are in the Wake Forest area?`, answer: `Several quality funeral homes serve Wake Forest and northern Wake County. Duane can recommend options and coordinate your pre-need plan with the home you choose.` },
  ],
  'holly-springs': [
    { question: `Is pre-need planning available in Holly Springs?`, answer: `Yes. Duane serves families throughout Holly Springs and southwestern Wake County. He's available for in-person or phone consultations.` },
    { question: `What does a funeral cost in Holly Springs, NC?`, answer: `Funeral costs in Holly Springs align with Wake County averages — approximately $7,848 or more. Pre-need insurance locks in today's prices to protect your family.` },
    { question: `How do I start pre-need planning in Holly Springs?`, answer: `Call Duane at ${PHONE}. He'll listen to your needs, explain your options, and set up a time to create your personalized plan. No pressure, no obligation.` },
  ],
  'fuquay-varina': [
    { question: `Does Duane serve Fuquay-Varina?`, answer: `Yes. Fuquay-Varina is part of Duane's service area in southern Wake County. He regularly works with families in the Fuquay-Varina community.` },
    { question: `What funeral homes serve Fuquay-Varina?`, answer: `Several funeral homes serve the Fuquay-Varina area. Duane can help you choose one that matches your needs and coordinate all the details.` },
    { question: `Can I meet Duane locally in Fuquay-Varina?`, answer: `Absolutely. Duane will meet you at your home or any convenient location in Fuquay-Varina. Phone consultations are also available.` },
  ],
  zebulon: [
    { question: `Is Duane available for families in Zebulon?`, answer: `Yes. Zebulon is part of Duane's service area in eastern Wake County. He's familiar with the community and is happy to help local families plan ahead.` },
    { question: `How much does pre-need insurance cost in Zebulon?`, answer: `Costs are the same regardless of your specific location — most families invest between $3,000 and $15,000 depending on their preferences. Duane will find options that work for your budget.` },
    { question: `What's the first step for Zebulon families?`, answer: `Call Duane at ${PHONE}. He answers personally — no call center. He'll listen to what brought you to pre-need planning and explain your options with zero pressure.` },
  ],
};

// Use FAQs from consts.ts (SC cities) or from the inline cityFaqs (NC cities)
const faqs = area.faq || cityFaqs[area.slug] || [];

const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE_TITLE,
  telephone: PHONE,
  email: EMAIL,
  url: SITE_URL,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Wendell',
    addressRegion: 'NC',
    postalCode: '27591',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: `${area.name}, ${area.state}`,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: `${area.county} County, ${area.state}`,
    },
  },
};

const faqJsonLd = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;
---

<BaseLayout title={title} description={description}>
  <Hero variant="interior" title={`Pre-Need Planning in ${area.name}, ${area.state}`} subtitle={`Helping ${area.name} families protect their loved ones from unexpected funeral costs`} />

  <section class="py-12 md:py-16 bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Service Areas', href: '/service-areas' }, { label: `${area.name}, ${area.state}` }]} />

      <div class="prose prose-lg max-w-none">
        {area.description ? (
          <p class="text-lg text-charcoal-500 mb-6">{area.description}</p>
        ) : (
          <p class="text-lg text-charcoal-500 mb-6">
            {area.name} is a vibrant community in {area.county} County, {stateName}. Duane Cutlip, a Licensed Preneed Funeral Director with over 20 years of experience, works with {area.name} families to create personalized pre-need funeral plans that protect their loved ones from difficult decisions and rising costs.
          </p>
        )}

        {area.highlights && area.highlights.length > 0 && (
          <div class="mt-6 mb-8">
            <h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-4">Why {area.name} Families Work with Duane</h2>
            <ul class="space-y-3">
              {area.highlights.map((highlight) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-teal-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-charcoal-500">{highlight}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {!area.highlights && (
          <>
            <h2 class="font-heading text-2xl font-bold text-charcoal-900 mt-10 mb-4">Why {area.name} Families Choose Pre-Need Planning</h2>
            <p class="text-charcoal-500 mb-4">
              The average funeral in {stateName} costs $7,848 or more — and prices continue to climb every year. For {area.name} families, pre-need insurance offers a way to lock in today's prices and ensure your wishes are documented before they're needed.
            </p>
            <p class="text-charcoal-500 mb-4">
              When you work with Duane, every detail is planned in advance: the type of service, the music, the flowers, and even the funeral home. Your family will never have to guess what you wanted, and they won't face unexpected bills during the hardest week of their lives.
            </p>

            <h2 class="font-heading text-2xl font-bold text-charcoal-900 mt-10 mb-4">Serving {area.name} and All of {area.county} County</h2>
            <p class="text-charcoal-500 mb-4">
              Duane is based in Wendell, NC, and serves families across {area.county} County. He's available to meet with you in {area.name} — at your home, a local meeting spot, or by phone. Most initial calls take about 15 minutes, and there's never any pressure or obligation.
            </p>
          </>
        )}

        <div class="mt-8 rounded-lg bg-linen border border-border-light p-6">
          <p class="font-heading text-lg font-bold text-charcoal-900 mb-2">Ready to learn more?</p>
          <p class="text-charcoal-500 mb-4">Call Duane directly for a free, no-pressure conversation:</p>
          <a href={`tel:${PHONE_RAW}`} class="inline-flex items-center gap-2 text-2xl font-heading font-bold text-burgundy-600 hover:text-burgundy-700">
            {PHONE}
          </a>
        </div>
      </div>

      {faqs.length > 0 && (
        <div class="mt-12">
          <h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-6">Common Questions from {area.name} Families</h2>
          <div class="space-y-6">
            {faqs.map((faq) => (
              <div class="border-b border-border-light pb-6">
                <h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2">{faq.question}</h3>
                <p class="text-charcoal-500">{faq.answer}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CTABanner />

  <JsonLd data={localBusinessJsonLd} />
  {faqJsonLd && <JsonLd data={faqJsonLd} />}
</BaseLayout>
