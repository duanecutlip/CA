---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABanner from '../components/CTABanner.astro';
import JsonLd from '../components/JsonLd.astro';
import { PHONE, PHONE_RAW, SITE_URL } from '../consts';

const title = 'Final Expense Insurance in North Carolina | Cutlip Associates';
const description = 'Simple, affordable final expense life insurance for North Carolina families. No medical exam. Multiple carriers. Free quote from licensed NC insurance agent Duane Cutlip.';

const serviceJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Service',
	name: 'Final Expense Life Insurance',
	description: 'Final expense whole life insurance for North Carolina families — affordable coverage with no medical exam required.',
	provider: {
		'@type': 'Person',
		'@id': `${SITE_URL}/#duane-cutlip`,
		name: 'Duane Cutlip',
		jobTitle: 'Licensed Insurance Agent',
		worksFor: {
			'@type': 'Organization',
			name: 'Cutlip Associates, LLC',
			url: SITE_URL,
		},
	},
	areaServed: { '@type': 'State', name: 'North Carolina' },
	serviceType: 'Final Expense Life Insurance',
};

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'What is final expense insurance?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Final expense insurance is a small whole life policy — typically $5,000 to $25,000 — designed to cover end-of-life costs like funeral expenses, outstanding medical bills, and other debts. The death benefit is paid in cash to your named beneficiary, who can use it for any purpose.',
			},
		},
		{
			'@type': 'Question',
			name: 'Do I need a medical exam for final expense insurance?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'No. Most final expense policies use simplified issue (a few health questions, no exam) or guaranteed issue (no questions at all) underwriting. Coverage is available for virtually every health situation, including serious pre-existing conditions.',
			},
		},
		{
			'@type': 'Question',
			name: 'How much does final expense insurance cost in North Carolina?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Premiums depend on your age, health, coverage amount, and the specific carrier. A healthy 65-year-old might pay $50 to $100 per month for $10,000 of coverage. Duane compares rates across multiple carriers to find the best value for your specific situation.',
			},
		},
		{
			'@type': 'Question',
			name: "What's the difference between final expense and preneed insurance?",
			acceptedAnswer: {
				'@type': 'Answer',
				text: "Preneed insurance is tied to a specific funeral plan with a specific funeral home — it locks in today's funeral prices and pays the funeral home directly. Final expense insurance is a general life insurance policy that pays cash to your beneficiary with no restrictions on how the money is used. Preneed is better for Medicaid planning and price protection; final expense offers more flexibility.",
			},
		},
	],
};
---

<BaseLayout title={title} description={description} keywords="final expense insurance NC, burial insurance North Carolina, final expense life insurance, funeral insurance no medical exam, final expense agent North Carolina, burial insurance no exam">
	<Hero
		variant="interior"
		title="Final Expense Insurance for North Carolina Families"
		subtitle="Simple, affordable whole life coverage that pays your family a cash benefit — no medical exam required. Available to any North Carolina resident."
	/>

	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Final Expense Insurance' }]} />

		<!-- What Is Final Expense Insurance? -->
		<section class="mb-16">
			<SectionHeading title="What Is Final Expense Insurance?" accent />
			<div class="prose max-w-none text-charcoal-700 space-y-4">
				<p class="text-lg leading-relaxed">
					Final expense insurance — also called burial insurance or funeral insurance — is a small whole life policy designed to cover end-of-life costs. Face amounts typically range from <strong>$5,000 to $25,000</strong>, and the death benefit is paid as cash to your named beneficiary.
				</p>
				<p class="leading-relaxed">
					Unlike <a href="/plan-ahead" class="text-teal-600 hover:text-teal-700 underline">preneed insurance</a>, which is tied to a specific funeral plan at a specific funeral home, final expense insurance puts money directly in your family's hands. They can use it for funeral costs, outstanding medical bills, credit card debt, travel expenses for out-of-town family members, or anything else that comes up.
				</p>
				<p class="leading-relaxed">
					Final expense is designed to be simple. There's no medical exam, no lengthy underwriting process, and no complicated paperwork. Most policies can be approved in days — sometimes the same day you apply.
				</p>
			</div>
		</section>

		<!-- Key Features -->
		<section class="mb-16">
			<SectionHeading title="Key Features" accent />
			<div class="grid sm:grid-cols-2 gap-6">
				{[
					{
						title: 'No Medical Exam',
						icon: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
						desc: "Most policies require only a few health questions — or none at all. Coverage is available for nearly every health situation, including serious pre-existing conditions like heart disease, COPD, or cancer history.",
					},
					{
						title: 'Cash Death Benefit',
						icon: 'M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z',
						desc: "Your beneficiary receives a lump sum — no restrictions, no funeral home requirements. They can use it for the funeral, medical bills, debt, travel, or daily living expenses.",
					},
					{
						title: 'Locked-In Premiums',
						icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
						desc: "Your premium is set the day you apply and never increases — not next year, not in ten years, not ever. The coverage amount you choose today is guaranteed for life.",
					},
					{
						title: 'Permanent Coverage',
						icon: 'M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
						desc: "Whole life insurance doesn't expire. Unlike term policies, your coverage stays in force for life — and builds a small cash value over time that you can borrow against if needed.",
					},
					{
						title: 'Multiple Carriers',
						icon: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
						desc: "Duane represents multiple highly-rated insurance carriers, not just one. That means he can shop the market for your specific age, health, and budget to find the best rate available to you.",
					},
					{
						title: 'Available Statewide',
						icon: 'M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z',
						desc: "Available to any North Carolina resident — not limited to a specific funeral home or county. Wherever you live in NC, Duane can help you find the right coverage.",
					},
				].map((feature) => (
					<div class="bg-white rounded-xl p-6 border border-border-light">
						<div class="flex items-center gap-3 mb-3">
							<div class="flex-shrink-0 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
								<svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
								</svg>
							</div>
							<h3 class="font-heading font-bold text-charcoal-900">{feature.title}</h3>
						</div>
						<p class="text-charcoal-500 text-sm leading-relaxed">{feature.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Who Is It For? -->
		<section class="mb-16">
			<SectionHeading title="Who Is Final Expense Insurance For?" accent />
			<div class="space-y-4">
				<p class="text-charcoal-700 leading-relaxed">
					Final expense insurance is a good fit for a wide range of situations. It tends to be the right choice when:
				</p>
				<ul class="space-y-3">
					{[
						{
							bold: 'You want coverage without a formal funeral plan',
							text: "You'd like to leave money for your family to handle final costs, but you're not ready to choose a specific funeral home or pre-arrange every detail in advance.",
						},
						{
							bold: "Your health makes traditional life insurance difficult",
							text: "Pre-existing conditions — heart disease, COPD, diabetes, cancer history — often disqualify people from standard life insurance. Final expense guaranteed-issue policies are available regardless of health.",
						},
						{
							bold: "You need smaller, more affordable coverage",
							text: "Not everyone needs a $500,000 life insurance policy. A $10,000 to $15,000 final expense policy provides meaningful protection at a premium that fits a fixed income.",
						},
						{
							bold: "You want to cover more than just the funeral",
							text: "Medical bills, credit card debt, utility bills, and immediate household costs don't stop when someone passes. Final expense gives your family cash to handle these without draining their savings.",
						},
						{
							bold: "You already have preneed but want a cash cushion",
							text: "If you have a preneed plan for the funeral itself, a supplemental final expense policy can cover the ancillary costs: travel for out-of-town family, meals, and the financial disruption of losing a household member.",
						},
						{
							bold: "You want fast, simple coverage",
							text: "Final expense can be approved in days with no exam, no blood draws, and minimal paperwork. For older adults who want straightforward coverage quickly, it's often the most practical path.",
						},
					].map((item) => (
						<li class="flex items-start gap-3">
							<svg class="w-5 h-5 text-teal-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
							</svg>
							<span class="text-charcoal-700"><strong class="text-charcoal-900">{item.bold}</strong> &mdash; {item.text}</span>
						</li>
					))}
				</ul>
			</div>
		</section>

		<!-- Policy Types -->
		<section class="mb-16">
			<SectionHeading title="Simplified Issue vs. Guaranteed Issue" accent />
			<div class="grid sm:grid-cols-2 gap-6">
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<h3 class="font-heading font-bold text-charcoal-900 text-lg mb-1">Simplified Issue</h3>
					<p class="text-teal-600 text-sm font-medium mb-3">Best rates for qualifying applicants</p>
					<p class="text-charcoal-500 text-sm leading-relaxed mb-4">
						A short set of yes/no health questions — typically 10 to 15 — with no physical exam, no blood work, and no lab results required. If you can answer "no" to most major health conditions, you'll qualify for significantly better rates than guaranteed issue.
					</p>
					<ul class="space-y-2">
						{[
							'No medical exam or lab work',
							'Better rates than guaranteed issue',
							'Full death benefit from day one',
							'Typically available ages 45–85',
						].map((item) => (
							<li class="flex items-start gap-2 text-charcoal-700 text-sm">
								<svg class="w-4 h-4 text-teal-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
				<div class="bg-white rounded-xl p-6 border border-border-light">
					<h3 class="font-heading font-bold text-charcoal-900 text-lg mb-1">Guaranteed Issue</h3>
					<p class="text-teal-600 text-sm font-medium mb-3">No health questions &mdash; everyone qualifies</p>
					<p class="text-charcoal-500 text-sm leading-relaxed mb-4">
						No health questions at all. If you're within the eligible age range, you're accepted — period. Premiums are higher and most carriers include a 2-year graded benefit period. The right choice for applicants with serious health conditions who can't qualify elsewhere.
					</p>
					<ul class="space-y-2">
						{[
							'No health questions — guaranteed acceptance',
							'Available regardless of health history',
							'Typically available ages 50–85',
							'2-year graded benefit (most carriers)',
						].map((item) => (
							<li class="flex items-start gap-2 text-charcoal-700 text-sm">
								<svg class="w-4 h-4 text-teal-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
								</svg>
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
			<p class="text-charcoal-500 text-sm mt-4 leading-relaxed">
				Duane will help you determine which type is best for your situation — and find the carrier offering the strongest value for that policy type at your age and health profile.
			</p>
		</section>

		<!-- Preneed vs Final Expense callout -->
		<section class="mb-16">
			<div class="bg-linen rounded-xl p-8 border border-border-light">
				<h2 class="font-heading text-xl font-bold text-charcoal-900 mb-3">Final Expense vs. Preneed: Which Is Right for You?</h2>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					Both products help cover funeral costs, but they work very differently. <strong>Preneed insurance</strong> locks in today's funeral prices, documents your exact wishes, and is Medicaid-exempt when irrevocable &mdash; the stronger choice for families concerned about Medicaid eligibility or who want every detail pre-arranged. <strong>Final expense insurance</strong> provides flexible cash that your family controls &mdash; better for those who want simplicity, need guaranteed acceptance, or want to cover more than just funeral costs.
				</p>
				<p class="text-charcoal-700 leading-relaxed mb-6">
					Many families benefit from both: a preneed plan handles the funeral, and a final expense policy covers the ancillary costs. Duane can help you find the right combination for your situation.
				</p>
				<a href="/learn/preneed-vs-final-expense" class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-semibold text-sm">
					Read the full preneed vs. final expense comparison
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
					</svg>
				</a>
			</div>
		</section>

		<!-- FAQ -->
		<section class="mb-16">
			<SectionHeading title="Frequently Asked Questions" accent />
			<div class="space-y-3 mt-6">
				{[
					{
						q: 'What is final expense insurance?',
						a: 'Final expense insurance is a small whole life policy — typically $5,000 to $25,000 — designed to cover end-of-life costs like funeral expenses, outstanding medical bills, and other debts. The death benefit is paid in cash to your named beneficiary, who can use it for any purpose.',
					},
					{
						q: 'Do I need a medical exam for final expense insurance?',
						a: 'No. Most final expense policies use simplified issue (a few health questions, no exam) or guaranteed issue (no questions at all) underwriting. Coverage is available for virtually every health situation, including serious pre-existing conditions.',
					},
					{
						q: 'How much does final expense insurance cost?',
						a: 'Premiums depend on your age, health, coverage amount, and carrier. A healthy 65-year-old might pay $50 to $100 per month for $10,000 of coverage. Duane compares rates across multiple carriers to find the best value for your specific situation — call him for a personalized quote with no obligation.',
					},
					{
						q: "What's the difference between final expense and preneed insurance?",
						a: "Preneed insurance is tied to a specific funeral plan at a specific funeral home — it locks in today's funeral prices and pays the funeral home directly. Final expense insurance is a general life insurance policy that pays cash to your beneficiary with no restrictions. Preneed is better for Medicaid planning and price protection; final expense offers more flexibility and is available to any NC resident regardless of which funeral home they may use.",
					},
					{
						q: 'Can I get coverage with serious health conditions?',
						a: "Yes. Guaranteed issue final expense policies are available regardless of health history — no health questions at all. These policies typically include a 2-year graded benefit period and have higher premiums than simplified issue, but they ensure coverage for applicants who can't qualify anywhere else.",
					},
					{
						q: 'How quickly can I get coverage?',
						a: 'Simplified issue policies are often approved within a few days. Guaranteed issue policies can sometimes be approved the same day you apply. Duane handles the application process and will let you know exactly what to expect based on the carrier and policy type.',
					},
					{
						q: 'Can I have both preneed insurance and final expense insurance?',
						a: 'Absolutely — and many families choose both. A preneed plan covers the funeral itself (price-locked, pre-arranged, paid to the funeral home), while a final expense policy provides a cash cushion for everything else: travel for out-of-town family, medical bills, immediate household expenses, and more.',
					},
					{
						q: 'Is final expense insurance right for someone on Medicaid?',
						a: "Final expense insurance is generally counted as a financial asset for Medicaid purposes, which can affect eligibility. If Medicaid is a concern, an irrevocable preneed funeral contract is typically the better choice — it's Medicaid-exempt in North Carolina. Duane can help you understand the difference and choose the right product for your situation.",
					},
				].map((item) => (
					<details class="group rounded-xl border border-border-light bg-white overflow-hidden">
						<summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-charcoal-900 font-heading font-semibold hover:bg-linen/50 transition-colors">
							{item.q}
							<svg class="w-5 h-5 text-charcoal-400 transition-transform duration-200 group-open:rotate-180 flex-shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9" /></svg>
						</summary>
						<div class="px-6 pb-5 text-charcoal-500 leading-relaxed">
							{item.a}
						</div>
					</details>
				))}
			</div>
		</section>

		<!-- CTA Section -->
		<section class="mb-8">
			<div class="bg-linen rounded-xl p-8 border border-border-light">
				<h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-3">Get a Free Final Expense Quote</h2>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					Duane is a licensed life, health, and accident insurance agent in North Carolina. He represents multiple carriers and will compare options across the market to find the right policy for your age, health, and budget &mdash; with no pressure and no obligation.
				</p>
				<p class="text-charcoal-700 leading-relaxed mb-6">
					Call him directly at <a href={`tel:${PHONE_RAW}`} class="text-teal-600 hover:text-teal-700 font-bold">{PHONE}</a> or reach out through the <a href="/contact" class="text-teal-600 hover:text-teal-700 underline">contact page</a>. Most initial conversations take about 15 minutes.
				</p>
				<p class="text-charcoal-500 text-sm">&mdash; Duane Cutlip, Licensed Insurance Agent, North Carolina</p>
			</div>
		</section>
	</div>

	<CTABanner
		title="Simple Coverage, Real Protection"
		subtitle="Duane shops multiple NC-licensed carriers to find the right final expense policy for your budget and health situation — call for a free, no-pressure quote."
	/>

	<JsonLd data={serviceJsonLd} />
	<JsonLd data={faqJsonLd} />
</BaseLayout>
