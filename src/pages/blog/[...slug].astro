---
import BlogPost from '../../layouts/BlogPost.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
	const localPosts = await getCollection('blog');
	const localPaths = localPosts.map((entry) => ({
		params: { slug: entry.slug },
		props: { source: 'local' as const, entry },
	}));

	let strapiPaths: { params: { slug: string }; props: { source: 'strapi'; article: any } }[] = [];
	try {
		const { getArticles } = await import('../../lib/strapi');
		const articles = await getArticles();
		strapiPaths = articles.map((article) => ({
			params: { slug: article.slug },
			props: { source: 'strapi' as const, article },
		}));
	} catch {}

	return [...localPaths, ...strapiPaths];
}

const { source } = Astro.props;

let title: string;
let description: string;
let pubDate: Date;
let updatedDate: Date | undefined;
let heroImage: string | undefined;
let htmlContent = '';
let Content: any = null;

if (source === 'local') {
	const { entry } = Astro.props;
	title = entry.data.title;
	description = entry.data.description;
	pubDate = entry.data.pubDate;
	updatedDate = entry.data.updatedDate;
	heroImage = entry.data.heroImage;
	const rendered = await entry.render();
	Content = rendered.Content;
} else {
	const { article } = Astro.props;
	title = article.title;
	description = article.description;
	pubDate = new Date(article.pubDate);
	updatedDate = article.updatedDate ? new Date(article.updatedDate) : undefined;
	heroImage = article.heroImage?.url;
	htmlContent = await marked(article.body || '');
}
---

<BlogPost
	title={title}
	description={description}
	pubDate={pubDate}
	updatedDate={updatedDate}
	heroImage={heroImage}
	slug={Astro.params.slug as string}
>
	{source === 'local' ? <Content /> : <Fragment set:html={htmlContent} />}
</BlogPost>
