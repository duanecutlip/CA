---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection } from 'astro:content';
import { PHONE } from '../../consts';

const title = 'Blog | Pre-Need Planning Resources';
const description = `Educational articles about pre-need insurance, funeral planning, and protecting your family. By Duane Cutlip. Call ${PHONE}.`;

// Load local content collection posts
const localPosts = (await getCollection('blog')).map((entry) => ({
	title: entry.data.title,
	description: entry.data.description,
	pubDate: entry.data.pubDate.toISOString(),
	slug: entry.id,
	source: 'local' as const,
}));

// Try to load Strapi articles too; merge if available
let strapiPosts: typeof localPosts = [];
try {
	const { getArticles } = await import('../../lib/strapi');
	const articles = await getArticles();
	strapiPosts = articles.map((a) => ({
		title: a.title,
		description: a.description,
		pubDate: a.pubDate,
		slug: a.slug,
		source: 'strapi' as const,
	}));
} catch {}

// Merge and sort by date descending
const articles = [...strapiPosts, ...localPosts].sort(
	(a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime(),
);
---

<BaseLayout title={title} description={description}>
	<Hero variant="interior" title="Blog" subtitle="Educational articles to help your family plan ahead with confidence." />

	<Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />

	<section class="py-16 md:py-24 bg-warm-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			{articles.length > 0 ? (
				<div class="grid gap-8">
					{articles.map((article) => (
						<a href={`/blog/${article.slug}`} class="block bg-white rounded-xl border border-border-light p-8 hover:border-teal-600/30 hover:shadow-sm transition-all">
							<h2 class="font-heading text-xl md:text-2xl font-bold text-charcoal-900 mb-3 hover:text-teal-600 transition-colors">
								{article.title}
							</h2>
							<p class="text-charcoal-500 leading-relaxed mb-4">
								{article.description}
							</p>
							<time class="text-sm text-charcoal-400" datetime={article.pubDate}>
								{new Date(article.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
							</time>
						</a>
					))}
				</div>
			) : (
				<div class="text-center py-12 bg-linen rounded-xl border border-border-light">
					<h2 class="font-heading text-2xl font-bold text-charcoal-900 mb-4">
						Articles Coming Soon
					</h2>
					<p class="text-charcoal-500 max-w-md mx-auto">
						We're working on educational resources to help families plan ahead. Check back soon, or call Duane directly with any questions.
					</p>
				</div>
			)}
		</div>
	</section>

	<CTABanner />
</BaseLayout>
