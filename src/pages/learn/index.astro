---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CTABanner from '../../components/CTABanner.astro';

const title = 'Learn About Preneed Insurance & Funeral Planning';
const description = 'Free guides on preneed insurance, funeral costs, Medicaid planning, VA benefits, and more. Learn everything you need to plan ahead with confidence.';

const guides = [
	{
		title: 'Preneed Insurance in North Carolina',
		href: '/learn/preneed-insurance-nc',
		desc: 'NC regulations, costs, carriers, and what families need to know. The complete guide to preneed planning in North Carolina.',
		tag: 'NC Guide',
	},
	{
		title: 'Preneed Insurance in South Carolina',
		href: '/learn/preneed-insurance-sc',
		desc: 'SC-specific regulations, pricing, trust requirements, and how preneed works for South Carolina families.',
		tag: 'SC Guide',
	},
	{
		title: 'Medicaid & Funeral Planning',
		href: '/learn/medicaid-funeral-planning',
		desc: 'How irrevocable preneed policies protect funeral funds from Medicaid spend-down. Essential reading for families navigating Medicaid.',
		tag: 'Medicaid',
	},
	{
		title: 'VA Funeral Benefits',
		href: '/learn/va-funeral-benefits',
		desc: 'What the VA covers, what it doesn\'t, and how preneed insurance fills the gap for veterans and military families.',
		tag: 'Veterans',
	},
	{
		title: 'Preneed vs Final Expense Insurance',
		href: '/learn/preneed-vs-final-expense',
		desc: 'They sound similar but work very differently. Understand the key differences and which one is right for your situation.',
		tag: 'Comparison',
	},
];

const quickLinks = [
	{
		title: 'Frequently Asked Questions',
		href: '/faq',
		desc: '30+ answers to the most common questions about preneed insurance, funeral planning, and working with Duane.',
		icon: 'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z',
	},
	{
		title: 'Pre-Planning Checklist',
		href: '/resources/pre-planning-checklist',
		desc: 'A step-by-step checklist to organize your funeral pre-planning. Print it out or work through it with your family.',
		icon: 'M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75',
	},
	{
		title: 'What to Expect',
		href: '/resources/what-to-expect',
		desc: 'Nervous about the process? Here\'s exactly what happens when you call Duane, from the first conversation to your completed plan.',
		icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
	},
	{
		title: 'Glossary of Terms',
		href: '/resources/glossary',
		desc: 'Funeral planning terms explained in plain English. No jargon, no confusion — just clear definitions.',
		icon: 'M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25',
	},
];

const audienceLinks = [
	{
		title: 'Help Your Parents Plan',
		href: '/help-your-parents-plan',
		desc: 'Researching for a parent? This page is for you — how to start the conversation and what to share with them.',
		audience: 'For adult children',
	},
	{
		title: 'Military Families',
		href: '/military-families',
		desc: 'VA burial benefits, the coverage gap, and how preneed insurance supplements what the VA provides.',
		audience: 'For veterans & families',
	},
	{
		title: 'Celebration of Life Planning',
		href: '/celebration-of-life',
		desc: 'Planning a personalized celebration that reflects a life well-lived — and how preneed covers every detail.',
		audience: 'For families',
	},
];
---

<BaseLayout title={title} description={description} keywords="preneed insurance guide, funeral planning education, preneed FAQ, funeral cost information, Medicaid funeral planning">
	<Hero variant="interior" title="Learn About Preneed Insurance & Funeral Planning" subtitle="Free guides, checklists, and answers to help you plan ahead with confidence." />

	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Learn' }]} />

		<!-- Understand Your Options -->
		<section class="mb-16">
			<SectionHeading title="Understand Your Options" accent />
			<p class="text-charcoal-500 mb-8 max-w-2xl">In-depth guides that explain how preneed insurance works, what it costs, and how regulations differ by state.</p>
			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{guides.map((guide) => (
					<a href={guide.href} class="group rounded-xl border border-border-light bg-white p-6 hover:border-teal-600/30 hover:shadow-md transition-all">
						<span class="inline-block px-2.5 py-0.5 bg-teal-600/10 text-teal-600 rounded-full text-xs font-medium mb-3">{guide.tag}</span>
						<h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2 group-hover:text-teal-600 transition-colors">{guide.title}</h3>
						<p class="text-charcoal-500 text-sm leading-relaxed">{guide.desc}</p>
					</a>
				))}
			</div>
		</section>

		<!-- Quick Reference -->
		<section class="mb-16">
			<SectionHeading title="Quick Reference" accent />
			<p class="text-charcoal-500 mb-8 max-w-2xl">Tools and answers for common questions — whether you're just starting to research or ready to take the next step.</p>
			<div class="grid sm:grid-cols-2 gap-6">
				{quickLinks.map((link) => (
					<a href={link.href} class="group flex items-start gap-4 rounded-xl border border-border-light bg-white p-6 hover:border-teal-600/30 hover:shadow-md transition-all">
						<div class="flex-shrink-0 flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600/10">
							<svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
							</svg>
						</div>
						<div>
							<h3 class="font-heading text-lg font-bold text-charcoal-900 mb-1 group-hover:text-teal-600 transition-colors">{link.title}</h3>
							<p class="text-charcoal-500 text-sm leading-relaxed">{link.desc}</p>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- By Audience -->
		<section class="mb-16">
			<SectionHeading title="Guides for Specific Situations" accent />
			<p class="text-charcoal-500 mb-8 max-w-2xl">Focused information for families in particular circumstances.</p>
			<div class="grid sm:grid-cols-3 gap-6">
				{audienceLinks.map((link) => (
					<a href={link.href} class="group rounded-xl border border-border-light bg-white p-6 hover:border-teal-600/30 hover:shadow-md transition-all">
						<span class="inline-block px-2.5 py-0.5 bg-gold-500/10 text-gold-600 rounded-full text-xs font-medium mb-3">{link.audience}</span>
						<h3 class="font-heading text-lg font-bold text-charcoal-900 mb-2 group-hover:text-teal-600 transition-colors">{link.title}</h3>
						<p class="text-charcoal-500 text-sm leading-relaxed">{link.desc}</p>
					</a>
				))}
			</div>
		</section>

		<!-- Blog Preview -->
		<section class="mb-16">
			<div class="bg-linen rounded-xl p-8 border border-border-light">
				<div class="flex flex-wrap items-center justify-between gap-4 mb-3">
					<h3 class="font-heading font-bold text-charcoal-900 text-xl">From the Blog</h3>
					<a href="/blog" class="inline-flex items-center gap-1 text-teal-600 hover:text-teal-700 font-medium text-sm">
						View all posts
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
						</svg>
					</a>
				</div>
				<p class="text-charcoal-500 leading-relaxed">
					Duane writes regularly about preneed insurance, funeral planning in the Carolinas, and helping families plan ahead. Visit the <a href="/blog" class="text-teal-600 hover:text-teal-700 underline">blog</a> for the latest articles.
				</p>
			</div>
		</section>

	</div>

	<CTABanner title="Still Have Questions?" subtitle="The best way to learn about your options is a free, no-pressure conversation with Duane. Most calls last about 15 minutes." />
</BaseLayout>
