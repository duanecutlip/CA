							<td class="p-4 text-charcoal-700">No — fixed dollar amount</td>
						</tr>
						<tr class="border-b border-border-light bg-linen/30">
							<td class="p-4 text-charcoal-700 font-semibold">Beneficiary controls funds</td>
							<td class="p-4 text-charcoal-700">No — funeral home receives payment</td>
							<td class="p-4 text-charcoal-700">Yes — can use for anything</td>
							<td class="p-4 text-charcoal-700">Yes — can use for anything</td>
						</tr>
