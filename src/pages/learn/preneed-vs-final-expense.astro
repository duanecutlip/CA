						</tr>
						<tr class="border-b border-border-light bg-linen/30">
							<td class="p-4 text-charcoal-700 font-semibold">Typical coverage amount</td>
							<td class="p-4 text-charcoal-700">$4,000–$20,000</td>
							<td class="p-4 text-charcoal-700">$5,000–$25,000</td>
							<td class="p-4 text-charcoal-700">$50,000–$1,000,000+</td>
						</tr>
