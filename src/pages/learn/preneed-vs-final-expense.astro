							<td class="p-4 text-charcoal-700 font-semibold">Who receives payment</td>
							<td class="p-4 text-charcoal-700">Funeral home directly</td>
							<td class="p-4 text-charcoal-700">Named beneficiary (cash)</td>
							<td class="p-4 text-charcoal-700">Named beneficiary (cash)</td>
						</tr>
						<tr class="border-b border-border-light bg-linen/30">
							<td class="p-4 text-charcoal-700 font-semibold">Documents your wishes</td>
							<td class="p-4 text-charcoal-700">Yes — every detail recorded</td>
							<td class="p-4 text-charcoal-700">No</td>
							<td class="p-4 text-charcoal-700">No</td>
						</tr>
						<tr class="border-b border-border-light">
							<td class="p-4 text-charcoal-700 font-semibold">Bypasses probate</td>
							<td class="p-4 text-charcoal-700">Yes — always</td>
							<td class="p-4 text-charcoal-700">Not always — depends on beneficiary setup</td>
							<td class="p-4 text-charcoal-700">Not always</td>
						</tr>
						<tr class="border-b border-border-light bg-linen/30">
							<td class="p-4 text-charcoal-700 font-semibold">Medicaid-exempt (North Carolina)</td>
							<td class="p-4 text-charcoal-700">Yes — when irrevocable</td>
							<td class="p-4 text-charcoal-700">Generally no — counted as an asset</td>
							<td class="p-4 text-charcoal-700">No</td>
						</tr>
