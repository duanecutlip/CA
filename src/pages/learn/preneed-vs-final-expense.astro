							<td class="p-4 text-charcoal-700">Yes — no restrictions</td>
						</tr>
						<tr class="border-b border-border-light">
							<td class="p-4 text-charcoal-700 font-semibold">Removes family's decision burden</td>
							<td class="p-4 text-charcoal-700">Yes — everything pre-arranged</td>
							<td class="p-4 text-charcoal-700">No — family still plans funeral</td>
							<td class="p-4 text-charcoal-700">No — family still plans funeral</td>
						</tr>
