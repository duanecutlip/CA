const title = 'Preneed Insurance in North Carolina | Complete Guide';
const description = "Everything NC families need to know about preneed insurance — costs, laws, Medicaid rules, carriers, and how to choose a plan. By Duane Cutlip, nearly 20 years experience.";
const keywords = 'preneed insurance North Carolina, NC preneed insurance, preneed funeral planning NC, Medicaid exempt funeral insurance NC, preneed insurance cost NC';

const faqItems = [
	{
		q: 'Is preneed insurance required in North Carolina?',
		a: 'No, preneed insurance is not legally required in North Carolina. However, it is one of the most practical and financially responsible ways to protect your family from the burden of unexpected funeral costs. Without a preneed plan, your loved ones will be forced to make expensive, emotionally charged decisions in the days immediately following your passing — often spending thousands more than necessary. Preneed insurance gives you the opportunity to make those decisions calmly, on your own terms, and at today\'s prices.',
	},
	{
		q: 'Can I transfer my NC preneed plan to another funeral home?',
		a: 'Yes. North Carolina law guarantees 100% contract transferability for preneed plans. This means you are never locked into a single funeral home. If you move to a different part of the state, or if your preferred funeral home changes ownership, you have the right to transfer your preneed plan — and all associated funds — to another licensed funeral home of your choosing. This is one of the strongest consumer protections in NC preneed law.',
	},
	{
		q: 'What happens to my preneed plan if I die before it\'s paid off?',
		a: 'It depends on your health at the time you applied. Applicants in good health typically receive full day-one coverage — meaning the insurance company pays the complete death benefit to the funeral home even if you have only made a few payments. Applicants with significant health issues may be placed on a graded benefit schedule for the first two years; however, even during that graded period, the carrier returns more than the total premiums paid if death occurs early. Either way, insurance-funded preneed provides substantially better protection than trust-funded plans, where only the amount deposited plus earnings would be available.',
	},
	{
		q: 'Is preneed insurance the same as burial insurance?',
		a: 'Not exactly. Preneed insurance is tied to a specific funeral plan and funeral home. When you purchase preneed insurance, you are documenting your exact wishes — service type, casket or urn, music, readings, flowers — and setting aside funds that go directly to the funeral home. Burial insurance (also called final expense insurance) is a general life insurance policy that pays a death benefit to your beneficiary, who can use it for anything. Preneed offers price protection and removes decision-making from your family; burial insurance offers flexibility but no price guarantee.',
	},
	{
		q: 'How do I verify a preneed agent is licensed in NC?',
		a: 'You can verify any preneed agent\'s license status by contacting the North Carolina Board of Funeral Service directly at (919) 733-9380 or by visiting their website. Licensed preneed funeral directors in North Carolina must maintain current licensing through the Board. Surety bonds are required of preneed licensees (funeral establishments holding preneed contracts). If someone offers to sell you a preneed plan but cannot provide their license number, that is a red flag.',
	},
	{
		q: 'Can I set up preneed insurance for my parents?',
