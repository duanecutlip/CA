---
import Button from './Button.astro';
import { PHONE, PHONE_RAW } from '../consts';

interface Props {
	variant: 'home' | 'interior' | 'blog';
	title: string;
	subtitle?: string;
	image?: string;
	imageAlt?: string;
	pubDate?: Date;
}

const { variant, title, subtitle, image, imageAlt, pubDate } = Astro.props;
---

{variant === 'home' && (
	<section class="bg-warm-white pt-24 pb-16 md:pt-32 md:pb-24">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div>
					<h1 class="font-heading text-4xl md:text-[48px] font-bold text-charcoal-900 leading-tight mb-6">
						{title}
					</h1>
					{subtitle && (
						<p class="text-xl text-charcoal-500 mb-8 leading-relaxed max-w-lg">
							{subtitle}
						</p>
					)}
					<div class="mb-8">
						<p class="text-sm text-charcoal-400 mb-2 font-body">Call Duane directly — no call center, no wait:</p>
						<a
							href={`tel:${PHONE_RAW}`}
							class="text-[32px] font-heading font-bold text-burgundy-600 hover:text-burgundy-700 transition-colors"
						>
							{PHONE}
						</a>
					</div>
					<div class="flex flex-wrap gap-4">
						<Button variant="primary" href="/how-it-works">
							See How It Works
						</Button>
						<Button variant="secondary" href="/plan-ahead">
							Learn About Pre-Need
						</Button>
					</div>
				</div>
				<div class="relative">
					{image ? (
						<img
							src={image}
							alt={imageAlt || 'Duane Cutlip, Licensed Preneed Funeral Director'}
							class="rounded-2xl w-full aspect-[4/5] object-cover"
							loading="eager"
						/>
					) : (
						<div class="rounded-2xl w-full aspect-[4/5] bg-linen flex items-center justify-center border border-border-light">
							<div class="text-center p-8">
								<div class="w-24 h-24 rounded-full bg-teal-600/10 mx-auto mb-4 flex items-center justify-center">
									<svg class="w-12 h-12 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
									</svg>
								</div>
								<p class="text-charcoal-400 text-sm">Photo of Duane Cutlip</p>
								<p class="text-charcoal-400 text-xs mt-1">Professional portrait placeholder</p>
							</div>
						</div>
					)}
				</div>
			</div>
		</div>
	</section>
)}

{variant === 'interior' && (
	<section class="bg-linen pt-24 pb-12 md:pt-32 md:pb-16">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="font-heading text-3xl md:text-[42px] font-bold text-charcoal-900 leading-tight mb-4">
				{title}
			</h1>
			{subtitle && (
				<p class="text-lg md:text-xl text-charcoal-500 max-w-2xl mx-auto leading-relaxed">
					{subtitle}
				</p>
			)}
		</div>
	</section>
)}

{variant === 'blog' && (
	<section class="bg-warm-white pt-24 pb-8 md:pt-32 md:pb-12">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
			<h1 class="font-heading text-3xl md:text-[40px] font-bold text-charcoal-900 leading-tight mb-4">
				{title}
			</h1>
			{subtitle && (
				<p class="text-lg text-charcoal-500 mb-4">{subtitle}</p>
			)}
			{pubDate && (
				<time class="text-sm text-charcoal-400" datetime={pubDate.toISOString()}>
					{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
				</time>
			)}
		</div>
	</section>
)}
