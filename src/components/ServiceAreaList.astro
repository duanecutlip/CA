---
import { SERVICE_AREAS } from '../consts';

interface Props {
	showLinks?: boolean;
}

const { showLinks = true } = Astro.props;

const ncAreas = SERVICE_AREAS.filter((a) => a.state === 'NC');

// Show core NC areas on homepage, collapse the rest
const coreRegions = ['Wake County', 'Triangle', 'Johnston County'];
const ncCore = ncAreas.filter((a) => coreRegions.includes(a.region || ''));
const ncExtended = ncAreas.filter((a) => !coreRegions.includes(a.region || ''));
---

<section class="py-16 md:py-24 bg-linen">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-4">
				Serving Families Across North Carolina
			</h2>
			<p class="text-charcoal-500 max-w-2xl mx-auto">
				Duane works with families throughout North Carolina — from Wake County and the Triangle to the Sandhills, the coast, and beyond.
			</p>
		</div>

		<div class="mb-8">
			<h3 class="font-heading text-lg font-semibold text-charcoal-700 mb-3">North Carolina</h3>
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
				{ncCore.map((area) => (
					showLinks ? (
						<a
							href={`/service-areas/${area.slug}`}
							class="flex items-center gap-2 bg-white rounded-lg border border-border-light px-4 py-3 hover:border-teal-600/30 hover:bg-teal-600/5 transition-colors"
						>
							<svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
							</svg>
							<span class="text-charcoal-700 font-medium">{area.name}</span>
						</a>
					) : (
						<div class="flex items-center gap-2 px-4 py-3">
							<svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
							</svg>
							<span class="text-charcoal-700">{area.name}</span>
						</div>
					)
				))}
			</div>
			{ncExtended.length > 0 && (
				<div class="mt-3 text-center">
					<a
						href="/service-areas"
						class="inline-flex items-center gap-1 text-teal-600 hover:text-teal-700 font-medium text-sm transition-colors"
					>
						+ {ncExtended.length} more NC towns
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
						</svg>
					</a>
				</div>
			)}
		</div>


	</div>
</section>
