---
import SectionHeading from './SectionHeading.astro';
import { TESTIMONIALS } from '../consts';

const testimonials = TESTIMONIALS;
---

<section class="py-16 md:py-24 bg-warm-white">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
		<SectionHeading
			title="What Families Are Saying"
			subtitle="Real families in Wake County who planned ahead with Duane."
			accent
		/>

		<div class="grid md:grid-cols-2 gap-6 mt-12">
			{testimonials.map((t) => (
				<div class="bg-white rounded-xl border border-border-light p-8">
					<div class="flex gap-1 mb-4" aria-label="5 out of 5 stars">
						{[1,2,3,4,5].map(() => (
							<svg class="w-5 h-5 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
								<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
							</svg>
						))}
					</div>
					<blockquote class="text-charcoal-700 leading-relaxed mb-6 italic">
						"{t.quote}"
					</blockquote>
					<div>
						<p class="font-heading font-semibold text-charcoal-900">{t.name}</p>
						<p class="text-sm text-charcoal-400">{t.relationship} &middot; {t.city}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
