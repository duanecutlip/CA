---
import { PHONE, PHONE_RAW } from '../consts';
---

<!-- Exit-intent / timed popup CTA -->
<div id="popup-overlay"
	class="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-charcoal-900/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
	aria-modal="true" role="dialog" aria-labelledby="popup-heading">

	<div id="popup-card"
		class="relative bg-warm-white rounded-2xl shadow-2xl max-w-md w-full p-8 translate-y-4 transition-transform duration-300">

		<!-- Close button -->
		<button id="popup-close"
			class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full text-charcoal-400 hover:text-charcoal-700 hover:bg-charcoal-100 transition-colors focus:outline-none focus:ring-2 focus:ring-teal-600/40"
			aria-label="Close">
			<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<!-- Content -->
		<div class="flex flex-col items-center text-center">

			<!-- Photo -->
			<div class="w-20 h-20 rounded-full overflow-hidden mb-4 ring-3 ring-teal-600/20">
				<img src="/images/duane-cutlip.png"
					alt="Duane Cutlip, Licensed Preneed Funeral Director"
					class="w-full h-full object-cover object-top"
					loading="lazy" />
			</div>

			<!-- Headline -->
			<h2 id="popup-heading" class="font-heading text-xl font-bold text-charcoal-900 mb-2">
				Most families aren't prepared.<br />Yours can be.
			</h2>

			<!-- Body -->
			<p class="text-charcoal-500 text-sm leading-relaxed mb-6">
				A free 15-minute call with Duane is all it takes to get started — no pressure, no obligation. He'll answer your questions and help you understand your options.
			</p>

			<!-- CTA buttons -->
			<div class="w-full space-y-3">
				<a href="/get-started"
					class="block w-full bg-teal-600 hover:bg-teal-700 text-white font-heading font-bold text-base px-6 py-3.5 rounded-xl transition-colors text-center">
					Start Your Free Plan
				</a>
				<a href={`tel:${PHONE_RAW}`}
					class="block w-full bg-burgundy-600 hover:bg-burgundy-700 text-white font-heading font-bold text-base px-6 py-3.5 rounded-xl transition-colors text-center">
					Call {PHONE}
				</a>
			</div>

			<!-- Dismiss link -->
			<button id="popup-dismiss"
				class="mt-4 text-xs text-charcoal-400 hover:text-charcoal-600 underline underline-offset-2 transition-colors focus:outline-none">
				No thanks — I'll decide later
			</button>
		</div>
	</div>
</div>

<script>
(function () {
  const STORAGE_KEY = 'ca-popup-dismissed';
  const DELAY_MS    = 40_000;   // 40 seconds
  const overlay     = document.getElementById('popup-overlay');
  const card        = document.getElementById('popup-card');
  const closeBtn    = document.getElementById('popup-close');
  const dismissBtn  = document.getElementById('popup-dismiss');

  // Don't show on the get-started page itself
  if (window.location.pathname.startsWith('/get-started')) return;

  // Don't show if dismissed in this browser session (or permanently)
  if (sessionStorage.getItem(STORAGE_KEY) || localStorage.getItem(STORAGE_KEY)) return;

  let shown = false;

  function show() {
    if (shown) return;
    shown = true;
    overlay.classList.remove('opacity-0', 'pointer-events-none');
    overlay.classList.add('opacity-100');
    card.classList.remove('translate-y-4');
    card.classList.add('translate-y-0');
    document.body.style.overflow = 'hidden';
  }

  function hide(permanent) {
    overlay.classList.add('opacity-0', 'pointer-events-none');
    overlay.classList.remove('opacity-100');
    card.classList.add('translate-y-4');
    card.classList.remove('translate-y-0');
    document.body.style.overflow = '';
    sessionStorage.setItem(STORAGE_KEY, '1');
    if (permanent) localStorage.setItem(STORAGE_KEY, '1');
  }

  // Trigger 1: 40-second delay
  const timer = setTimeout(show, DELAY_MS);

  // Trigger 2: exit intent (mouse leaving toward top of viewport)
  document.addEventListener('mouseleave', (e) => {
    if (e.clientY < 10) {
      clearTimeout(timer);
      show();
    }
  });

  // Close on button / dismiss / overlay click
  closeBtn.addEventListener('click', () => hide(false));
  dismissBtn.addEventListener('click', () => hide(true));
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) hide(false);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && shown) hide(false);
  });
})();
</script>
