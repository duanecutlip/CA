---
import Button from './Button.astro';
import { PHONE, PHONE_RAW } from '../consts';
---

<section class="py-16 md:py-24 bg-warm-white">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<div class="relative">
				<img
					src="/images/duane-cutlip.png"
					alt="Duane Cutlip, Licensed Preneed Funeral Director"
					class="rounded-2xl w-full aspect-[4/5] object-contain"
					loading="lazy"
				/>
			</div>
			<div>
				<h2 class="font-heading text-3xl md:text-4xl font-bold text-charcoal-900 mb-6">
					Meet Duane Cutlip
				</h2>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					For nearly 20 years, Duane has helped families across the Raleigh-Wake County area plan ahead with confidence. As a Licensed Preneed Funeral Director, he brings deep expertise and genuine compassion to every conversation.
				</p>
				<p class="text-charcoal-700 leading-relaxed mb-4">
					Duane isn't a salesperson — he's a neighbor. He lives in the greater Triangle area with his wife Angie and their two daughters. He's active in his church, volunteers as an ARRL ham radio examiner, and is deeply rooted in the communities he serves.
				</p>
				<p class="text-charcoal-500 leading-relaxed mb-8">
					"I got into this work because I saw too many families blindsided by decisions they weren't prepared to make. Planning ahead is one of the most loving things you can do for the people you care about."
				</p>
				<div class="flex flex-wrap gap-4">
					<Button variant="primary" href="/about">
						Read Duane's Full Story
					</Button>
					<Button variant="phone" href={`tel:${PHONE_RAW}`}>
						Call {PHONE}
					</Button>
				</div>
			</div>
		</div>
	</div>
</section>
