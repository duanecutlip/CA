---
import { SITE_TITLE, PHONE, PHONE_RAW, EMAIL, ADDRESS, LICENSE, FOOTER_NAV } from '../consts';
const year = new Date().getFullYear();
---

<footer class="bg-footer text-white/90">
  <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Planning -->
      <div>
        <h3 class="mb-4 font-heading text-lg font-bold !text-white">Planning</h3>
        <ul class="space-y-2.5">
          {FOOTER_NAV.planning.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h3 class="mb-4 font-heading text-lg font-bold !text-white">Learn</h3>
        <ul class="space-y-2.5">
          {FOOTER_NAV.learn.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="mb-4 font-heading text-lg font-bold !text-white">Company</h3>
        <ul class="space-y-2.5">
          {FOOTER_NAV.company.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- For Professionals -->
      <div>
        <h3 class="mb-4 font-heading text-lg font-bold !text-white">For Professionals</h3>
        <ul class="space-y-2.5">
          {FOOTER_NAV.professionals.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="mb-4 font-heading text-lg font-bold !text-white">Contact</h3>
        <div class="space-y-3">
          <a
            href={`tel:${PHONE_RAW}`}
            class="block font-heading text-xl font-bold !text-white hover:!text-white/80 no-underline transition-colors"
          >
            {PHONE}
          </a>
          <p class="text-white/70">{ADDRESS}</p>
          <a href={`mailto:${EMAIL}`} class="text-white/70 hover:text-white transition-colors">
            {EMAIL}
          </a>
          <p class="text-sm text-white/70">{LICENSE}</p>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-10 flex flex-col items-center gap-3 border-t border-white/10 pt-6 md:flex-row md:justify-between">
      <div class="flex flex-wrap justify-center gap-4 text-sm text-white/70">
        {FOOTER_NAV.legal.map((link) => (
          <a href={link.href} class="hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-sm text-white/70">
        &copy; {year} {SITE_TITLE}. Duane Cutlip, Licensed Preneed Funeral Director.
      </p>
    </div>
  </div>
</footer>
