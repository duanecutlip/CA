---
interface Props {
	heading?: string;
	subheading?: string;
}

const {
	heading = 'Schedule a Free Callback',
	subheading = "Pick a date and time that works for you. Duane will call you personally — no salespeople, no pressure.",
} = Astro.props;
---

<!--
	BIRBOL SCHEDULING WIDGET PLACEHOLDER
	When ready to go live, replace this entire component with:

	<div data-birbol-booking="cutlip/30-min-consultation" data-birbol-theme="light"></div>
	<script src="https://widget.birbol.com/embed.js"></script>

	The embed auto-sizes via postMessage and supports UTM passthrough.
	See: scheduler/web/loader/embed.js for full docs.
-->
<div class="rounded-xl border-2 border-dashed border-teal-600/30 bg-linen p-8 md:p-10">
	<div class="text-center mb-6">
		<h3 class="font-heading text-xl md:text-2xl font-bold text-charcoal-900">{heading}</h3>
		<p class="mt-2 text-charcoal-500 max-w-md mx-auto">{subheading}</p>
	</div>

	<!-- Placeholder calendar mockup so Duane can see the layout -->
	<div class="bg-white rounded-lg border border-border-light p-6 min-h-[400px] flex flex-col items-center justify-center gap-4">
		<svg class="w-16 h-16 text-teal-600/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
			<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
		</svg>
		<p class="font-heading text-lg font-semibold text-charcoal-400">Birbol Scheduling Widget</p>
		<p class="text-sm text-charcoal-400 max-w-sm text-center">
			Calendar date picker &rarr; time slot selection &rarr; booking form will appear here.
		</p>
		<p class="text-xs text-charcoal-300 mt-2">Replace this placeholder with the birbol embed code when ready.</p>
	</div>

	<p class="mt-4 text-xs text-charcoal-400 text-center">
		Your information stays private and is never shared.
	</p>
</div>
