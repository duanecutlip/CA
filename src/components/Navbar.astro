---
import { SITE_TITLE, NAV_LINKS, PHONE, PHONE_RAW } from '../consts';
import MobileNav from './MobileNav.tsx';
---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-nav transition-shadow duration-200"
>
  <nav class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-5 lg:px-8" aria-label="Main navigation">
    <!-- Logo / Site Name -->
    <a href="/" class="font-heading text-xl font-bold text-charcoal-900 whitespace-nowrap">
      {SITE_TITLE.split(',')[0]}
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden md:flex items-center gap-6">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-body text-base font-medium text-charcoal-700 hover:text-teal-600 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Phone (Desktop) -->
    <a
      href={`tel:${PHONE_RAW}`}
      class="hidden md:flex items-center gap-2 font-heading text-base font-bold text-burgundy-600 hover:text-burgundy-700 transition-colors whitespace-nowrap"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {PHONE}
    </a>

    <!-- Mobile Menu Button -->
    <MobileNav client:media="(max-width: 767px)" />
  </nav>
</header>

<!-- Spacer for fixed nav -->
<div class="h-[72px]"></div>

<script>
  const sentinel = document.getElementById('nav-sentinel');
  const nav = document.getElementById('main-nav');

  if (sentinel && nav) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          nav.classList.remove('shadow-sm', 'border-b', 'border-border-light');
        } else {
          nav.classList.add('shadow-sm', 'border-b', 'border-border-light');
        }
      },
      { threshold: 1.0 }
    );
    observer.observe(sentinel);
  }
</script>
